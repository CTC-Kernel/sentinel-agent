{
  "model": {
    "name": "qwen3-coder-7b",
    "path": "models/qwen3-coder-7b.Q4_K_M.gguf",
    "model_type": "Qwen3Coder",
    "capabilities": {
      "code_analysis": true,
      "security_analysis": true,
      "remediation": true,
      "classification": true,
      "summarization": true
    },
    "max_context_size": 4096,
    "gpu_layers": 0,
    "threads": 4
  },
  "inference": {
    "temperature": 0.7,
    "top_p": 0.9,
    "top_k": 40,
    "repetition_penalty": 1.1,
    "max_tokens": 1024,
    "timeout_secs": 30
  },
  "cache": {
    "enabled": true,
    "directory": "cache/llm",
    "max_size_mb": 1024,
    "ttl_hours": 24
  },
  "security": {
    "sanitize_input": true,
    "max_input_length": 10000,
    "blocked_patterns": [
      "(?i)password\\s*[:=]\\s*\\S+",
      "(?i)secret\\s*[:=]\\s*\\S+",
      "(?i)token\\s*[:=]\\s*\\S+"
    ],
    "audit_logging": true
  }
}
