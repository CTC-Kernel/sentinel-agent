{
  "server": {
    "url": "https://your-sentinel-server.example.com",
    "token": "YOUR_ENROLLMENT_TOKEN_HERE"
  },
  "agent": {
    "id": null,
    "name": "Sentinel Agent",
    "description": "Agent de conformité endpoint"
  },
  "gui": {
    "enabled": true,
    "autostart": true,
    "minimize_to_tray": true
  },
  "logging": {
    "level": "info",
    "file": "C:\\ProgramData\\Sentinel\\logs\\agent.log",
    "max_size": "10MB",
    "max_files": 5
  },
  "collection": {
    "interval_seconds": 300,
    "enable_network": true,
    "enable_security": true,
    "enable_compliance": true
  }
}
