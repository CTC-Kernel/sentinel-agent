{
  "server_url": "https://app.cyber-threat-consulting.com",

  "agent_id": null,

  "check_interval_secs": 3600,

  "heartbeat_interval_secs": 60,

  "offline_mode_days": 7,

  "log_level": "info",

  "db_path": "~/.local/share/sentinel-grc/agent.db",

  "tls_verify": true,

  "ca_cert_path": "/etc/ssl/certs/custom-ca.crt",

  "enrollment_token": "ent_XXXXXXXXXXXXXXXXXXXX",

  "proxy": {
    "url": "http://proxy.example.com:8080",
    "username": "proxy_user",
    "password": "proxy_password"
  },

  "fim_watched_paths": [
    "/etc",
    "/var/log",
    "/home"
  ],

  "fim_ignore_patterns": [
    "*.log",
    "*.tmp",
    "*.swp"
  ],

  "usb_monitoring": true,

  "usb_block_mass_storage": false,

  "active_frameworks": ["ISO27001", "NIST-CSF"]
}
