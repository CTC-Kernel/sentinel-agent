rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : {'role': 'none', 'organizationId': 'none'};
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }
    
    function isAuditor() {
      return isAuthenticated() && getUserData().role == 'auditor';
    }
    
    function isRSSI() {
      return isAuthenticated() && getUserData().role == 'rssi';
    }

    function isProjectManager() {
      return isAuthenticated() && getUserData().role == 'project_manager';
    }


    
    function belongsToOrganization(orgId) {
      return isAuthenticated() && getUserData().organizationId == orgId;
    }
    
    function canRead(orgId) {
      return belongsToOrganization(orgId);
    }
    
    function canWrite(orgId) {
      return belongsToOrganization(orgId) && (isAdmin() || isAuditor() || isRSSI());
    }
    
    function canDelete(orgId) {
      return belongsToOrganization(orgId) && (isAdmin() || isRSSI());
    }
    
    // Organizations
    match /organizations/{orgId} {
      allow read: if belongsToOrganization(orgId) || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if belongsToOrganization(orgId) && (isAdmin() || resource.data.ownerId == request.auth.uid);
      allow delete: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        belongsToOrganization(resource.data.organizationId)
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        (
          request.auth.uid == userId && (
            // Case 1: Initial Setup (Onboarding) - OrgId is empty or being set for first time
            (!('organizationId' in resource.data) || resource.data.organizationId == null) ||
            
            // Case 2: Standard Update - Prevent tampering with critical fields (role, organizationId)
            (
              request.resource.data.role == resource.data.role &&
              request.resource.data.organizationId == resource.data.organizationId
            ) ||
            
            // Case 3: Owner/Admin override - Can change anything within their scope if they own the org
            request.auth.uid == get(/databases/$(database)/documents/organizations/$(resource.data.organizationId)).data.ownerId
          )
        ) || 
        (isAdmin() && belongsToOrganization(resource.data.organizationId))
      );
      allow delete: if isAdmin() && belongsToOrganization(resource.data.organizationId);
    }
    
    // Join Requests
    match /join_requests/{requestId} {
      allow read: if isAuthenticated() && (
        request.auth.token.email == resource.data.userEmail ||
        belongsToOrganization(resource.data.organizationId)
      );
      allow create: if isAuthenticated();
      allow update: if belongsToOrganization(resource.data.organizationId) && isAdmin();
      allow delete: if belongsToOrganization(resource.data.organizationId) && isAdmin();
    }

    // Invitations
    match /invitations/{invitationId} {
      allow read: if isAuthenticated() && (
        request.auth.token.email == resource.data.email ||
        belongsToOrganization(resource.data.organizationId)
      );
      allow create: if isAuthenticated() && isAdmin() && request.resource.data.organizationId == getUserData().organizationId;
      allow delete: if isAuthenticated() && (
        (isAdmin() && belongsToOrganization(resource.data.organizationId)) ||
        request.auth.token.email == resource.data.email
      );
    }
    
    // Risk History
    match /risk_history/{historyId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if false; // History is immutable
      allow delete: if canDelete(resource.data.organizationId);
    }
    
    // Assets
    match /assets/{assetId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if (isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId)) || (
          request.resource.data.source == 'Kiosk Intake' &&
          request.resource.data.organizationId is string &&
          request.resource.data.name is string &&
          request.resource.data.serialNumber is string
        );
      allow update: if canWrite(resource.data.organizationId);
      allow delete: if canDelete(resource.data.organizationId);
      
      // Maintenance subcollection
      match /maintenance/{maintenanceId} {
        allow read: if canRead(get(/databases/$(database)/documents/assets/$(assetId)).data.organizationId);
        allow write: if canWrite(get(/databases/$(database)/documents/assets/$(assetId)).data.organizationId);
      }
    }
    
    // Risks
    match /risks/{riskId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if canWrite(resource.data.organizationId);
      allow delete: if canDelete(resource.data.organizationId);
    }
    
    // Controls (ISO 27001)
    match /controls/{controlId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if canWrite(resource.data.organizationId);
      allow delete: if canDelete(resource.data.organizationId);
    }
    
    // Audits
    match /audits/{auditId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        (isAdmin() || isAuditor());
      allow update: if isAdmin() || isAuditor();
      allow delete: if canDelete(resource.data.organizationId);
    }

    // Audit Checklists
    match /audit_checklists/{checklistId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        (isAdmin() || isAuditor());
      allow update: if isAdmin() || isAuditor();
      allow delete: if canDelete(resource.data.organizationId);
    }
    
    // Findings
    match /findings/{findingId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        (isAdmin() || isAuditor());
      allow update: if isAdmin() || isAuditor();
      allow delete: if canDelete(resource.data.organizationId);
    }
    
    // Projects
    match /projects/{projectId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        (canWrite(request.resource.data.organizationId) || isProjectManager());
      allow update: if canWrite(resource.data.organizationId) || (isProjectManager() && belongsToOrganization(resource.data.organizationId));
      allow delete: if canDelete(resource.data.organizationId) || (isProjectManager() && belongsToOrganization(resource.data.organizationId));
    }
    
    // Project Milestones
    match /project_milestones/{milestoneId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        (canWrite(request.resource.data.organizationId) || isProjectManager());
      allow update: if canWrite(resource.data.organizationId) || (isProjectManager() && belongsToOrganization(resource.data.organizationId));
      allow delete: if canDelete(resource.data.organizationId) || (isProjectManager() && belongsToOrganization(resource.data.organizationId));
    }
    
    // Incidents
    match /incidents/{incidentId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId;
      allow update: if canWrite(resource.data.organizationId);
      allow delete: if canDelete(resource.data.organizationId);
    }
    
    // Incident Playbooks (global library)
    match /incidentPlaybooks/{playbookId} {
      // Playbooks ne contiennent pas de données spécifiques à une organisation
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isAdmin() || isRSSI() || isAuditor());
      allow update: if isAuthenticated() && (isAdmin() || isRSSI() || isAuditor());
      allow delete: if isAuthenticated() && (isAdmin() || isRSSI());
    }

    // Incident Responses (liées aux incidents et donc aux organisations)
    match /incidentResponses/{responseId} {
      allow read: if canRead(get(/databases/$(database)/documents/incidents/$(resource.data.incidentId)).data.organizationId);
      allow create: if isAuthenticated() &&
        canWrite(get(/databases/$(database)/documents/incidents/$(request.resource.data.incidentId)).data.organizationId);
      allow update: if canWrite(get(/databases/$(database)/documents/incidents/$(resource.data.incidentId)).data.organizationId);
      allow delete: if canDelete(get(/databases/$(database)/documents/incidents/$(resource.data.incidentId)).data.organizationId);
    }
    
    // Documents
    match /documents/{documentId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        (canWrite(request.resource.data.organizationId) || isProjectManager());
      allow update: if canWrite(resource.data.organizationId) || (isProjectManager() && belongsToOrganization(resource.data.organizationId));
      allow delete: if canDelete(resource.data.organizationId) || (isProjectManager() && belongsToOrganization(resource.data.organizationId));
    }
    
    // Suppliers
    match /suppliers/{supplierId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if canWrite(resource.data.organizationId);
      allow delete: if canDelete(resource.data.organizationId);
    }
    
    // Supplier Assessments
    match /supplierAssessments/{assessmentId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if canWrite(resource.data.organizationId);
      allow delete: if canDelete(resource.data.organizationId);
    }

    // Supplier Incidents
    match /supplierIncidents/{incidentId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if canWrite(resource.data.organizationId);
      allow delete: if canDelete(resource.data.organizationId);
    }
    
    // Processing Activities (GDPR)
    match /processing_activities/{activityId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if canWrite(resource.data.organizationId);
      allow delete: if canDelete(resource.data.organizationId);
    }
    
    // Business Processes (BCP/DRP)
    match /business_processes/{processId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if canWrite(resource.data.organizationId);
      allow delete: if canDelete(resource.data.organizationId);
    }
    
    // BCP Drills
    match /bcp_drills/{drillId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if canWrite(resource.data.organizationId);
      allow delete: if canDelete(resource.data.organizationId);
    }
    
    // System Logs (Audit Trail)
    match /system_logs/{logId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && (
        request.resource.data.organizationId == getUserData().organizationId ||
        request.auth.uid == get(/databases/$(database)/documents/organizations/$(request.resource.data.organizationId)).data.ownerId
      );
      allow update: if false; // Logs are immutable
      allow delete: if false; // Logs cannot be deleted
    }
    
    // Stats History
    match /stats_history/{statId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }
    
    // Comments (for any resource)
    match /assets/{assetId}/comments/{commentId} {
      allow read: if canRead(get(/databases/$(database)/documents/assets/$(assetId)).data.organizationId);
      allow create: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/assets/$(assetId)).data.organizationId);
      allow update: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/assets/$(assetId)).data.organizationId) &&
        request.auth.uid == resource.data.userId;
      allow delete: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/assets/$(assetId)).data.organizationId) && (
          request.auth.uid == resource.data.userId || 
          isAdmin()
        );
    }
    
    match /risks/{riskId}/comments/{commentId} {
      allow read: if canRead(get(/databases/$(database)/documents/risks/$(riskId)).data.organizationId);
      allow create: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/risks/$(riskId)).data.organizationId);
      allow update: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/risks/$(riskId)).data.organizationId) &&
        request.auth.uid == resource.data.userId;
      allow delete: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/risks/$(riskId)).data.organizationId) && (
          request.auth.uid == resource.data.userId || 
          isAdmin()
        );
    }
    
    match /projects/{projectId}/comments/{commentId} {
      allow read: if canRead(get(/databases/$(database)/documents/projects/$(projectId)).data.organizationId);
      allow create: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/projects/$(projectId)).data.organizationId);
      allow update: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/projects/$(projectId)).data.organizationId) &&
        request.auth.uid == resource.data.userId;
      allow delete: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/projects/$(projectId)).data.organizationId) && (
          request.auth.uid == resource.data.userId || 
          isAdmin()
        );
    }

    match /documents/{documentId}/comments/{commentId} {
      allow read: if canRead(get(/databases/$(database)/documents/documents/$(documentId)).data.organizationId);
      allow create: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/documents/$(documentId)).data.organizationId);
      allow update: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/documents/$(documentId)).data.organizationId) &&
        request.auth.uid == resource.data.userId;
      allow delete: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/documents/$(documentId)).data.organizationId) && (
          request.auth.uid == resource.data.userId || 
          isAdmin()
        );
    }

    match /suppliers/{supplierId}/comments/{commentId} {
      allow read: if canRead(get(/databases/$(database)/documents/suppliers/$(supplierId)).data.organizationId);
      allow create: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/suppliers/$(supplierId)).data.organizationId);
      allow update: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/suppliers/$(supplierId)).data.organizationId) &&
        request.auth.uid == resource.data.userId;
      allow delete: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/suppliers/$(supplierId)).data.organizationId) && (
          request.auth.uid == resource.data.userId || 
          isAdmin()
        );
    }

    match /processing_activities/{activityId}/comments/{commentId} {
      allow read: if canRead(get(/databases/$(database)/documents/processing_activities/$(activityId)).data.organizationId);
      allow create: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/processing_activities/$(activityId)).data.organizationId);
      allow update: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/processing_activities/$(activityId)).data.organizationId) &&
        request.auth.uid == resource.data.userId;
      allow delete: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/processing_activities/$(activityId)).data.organizationId) && (
          request.auth.uid == resource.data.userId || 
          isAdmin()
        );
    }

    match /business_processes/{processId}/comments/{commentId} {
      allow read: if canRead(get(/databases/$(database)/documents/business_processes/$(processId)).data.organizationId);
      allow create: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/business_processes/$(processId)).data.organizationId);
      allow update: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/business_processes/$(processId)).data.organizationId) &&
        request.auth.uid == resource.data.userId;
      allow delete: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/business_processes/$(processId)).data.organizationId) && (
          request.auth.uid == resource.data.userId || 
          isAdmin()
        );
    }
    
    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        belongsToOrganization(resource.data.organizationId)
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
    }

    // Backups
    match /backups/{backupId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        (isAdmin() || isAuditor());
      allow update: if canWrite(resource.data.organizationId);
      allow delete: if canDelete(resource.data.organizationId);
    }

    // Backup Schedules
    match /backup_schedules/{scheduleId} {
      allow read: if isAuthenticated() && 
        resource.data.organizationId == getUserData().organizationId;
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        (isAdmin() || isAuditor());
      allow update: if isAuthenticated() && 
        resource.data.organizationId == getUserData().organizationId &&
        (isAdmin() || isAuditor());
      allow delete: if canDelete(resource.data.organizationId);
    }

    // Mail Queue (for Cloud Functions)
    match /mail_queue/{mailId} {
      allow read: if false; // Only Cloud Functions need to read
      allow create: if isAuthenticated(); // Users trigger emails
      allow update: if false;
      allow delete: if false;
    }

    // Scheduled Emails (for Cloud Functions / Cron)
    match /scheduled_emails/{emailId} {
      allow read: if false; // Traitement côté backend uniquement
      allow create: if isAuthenticated(); // Les utilisateurs planifient des emails
      allow update: if false;
      allow delete: if false;
    }
    
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
