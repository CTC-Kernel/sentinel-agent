rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      // Require custom claims for performance and security
      // Falls back to 'none' if claims are not yet set (e.g. pending backend sync)
      return request.auth.token.keys().hasAny(['organizationId']) 
        ? request.auth.token 
        : {'role': 'none', 'organizationId': 'none'};
    }
    
    // Role Checks
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    // --- ADMIN ROLE SEMANTICS ---
    // isOrgAdmin(): True if user has 'admin' role for their organization
    // isSuperAdmin(): True if user has system-wide super-admin privileges
    // isAdmin(): Returns true for EITHER org admin OR super admin
    //            IMPORTANT: Always use with belongsToOrganization() for write operations
    //            to ensure proper tenant isolation. Super-admin alone does NOT bypass org checks.
    function isOrgAdmin() { return request.auth.token.role == 'admin'; }
    function isSuperAdmin() { return request.auth.token.superAdmin == true; }
    function isAdmin() { return isOrgAdmin() || isSuperAdmin(); }
    function isRSSI() { return hasRole('rssi'); }
    function isAuditor() { return hasRole('auditor'); }
    function isProjectManager() { return hasRole('project_manager'); }

    function isUser() { return hasRole('user'); }

    // Ownership Check
    function isOrgOwner(orgId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid;
    }

    // Tenant Isolation
    function belongsToOrganization(orgId) {
      return isAuthenticated() && getUserData().organizationId == orgId;
    }

    // --- VALIDATION HELPERS ---
    function isValidString(text, min, max) {
      return text is string && text.size() >= min && text.size() <= max;
    }
    

    
    function isValidIncidentStatus(status) {
      return status in ['Nouveau', 'Analyse', 'Contenu', 'Résolu', 'Fermé'];
    }

    // UNIFIED: Use French Criticality values for all severity fields
    // Matches TypeScript Criticality type: 'Faible' | 'Moyenne' | 'Élevée' | 'Critique'
    function isValidCriticality(val) {
      return val in ['Faible', 'Moyenne', 'Élevée', 'Critique'];
    }

    function isValidAssetType(val) {
      return val in ['Matériel', 'Logiciel', 'Données', 'Service', 'Humain'];
    }

    // --- PHASE 19 HARDENING HELPERS ---
    
    function isValidRiskLevel(val) {
      return val is int && val >= 1 && val <= 5;
    }

    function isValidRiskStatus(val) {
      return val in ['Ouvert', 'En cours', 'Fermé', 'En attente de validation', 'Brouillon'];
    }

    function isValidRiskStrategy(val) {
      return val in ['Accepter', 'Atténuer', 'Transférer', 'Éviter'];
    }

    function isValidSupplierCategory(val) {
      return val in ['SaaS', 'Hébergement', 'Matériel', 'Consulting', 'Autre'];
    }

    function isValidProcessingActivityStatus(val) {
      return val in ['Actif', 'En projet', 'Archivé'];
    }

    function isValidLegalBasis(val) {
      return val in ['Consentement', 'Contrat', 'Obligation Légale', 'Intérêt Légitime', 'Sauvegarde Intérêts', 'Mission Publique'];
    }

    // --- CLASSIFICATION HELPERS (Story 24.3) ---
    // Document classification levels: public, internal, confidential, secret

    function isValidClassification(level) {
      return level in ['public', 'internal', 'confidential', 'secret'];
    }

    // Check if user role can access a classification level
    // public: all authenticated users
    // internal: all authenticated users (user, project_manager, rssi, admin, super_admin)
    // confidential: project_manager, rssi, admin, super_admin only
    // secret: rssi, admin, super_admin only
    function canAccessClassificationLevel(classification, role) {
      return classification == 'public' ||
             (classification == 'internal' && role in ['user', 'auditor', 'project_manager', 'rssi', 'admin', 'super_admin', 'direction']) ||
             (classification == 'confidential' && role in ['project_manager', 'rssi', 'admin', 'super_admin', 'direction']) ||
             (classification == 'secret' && role in ['rssi', 'admin', 'super_admin']);
    }

    // Check if user can access document based on classification
    function canAccessDocumentClassification(docData) {
      let classification = docData.get('classification', {}).get('level', 'internal');
      let userRole = getUserData().role;
      return canAccessClassificationLevel(classification, userRole);
    }

    // Check if user has explicit ACL permission on a document
    // Checks user ID, role, and group memberships against ACL permissions
    function hasExplicitAclPermission(docData, requiredAccess) {
      let acl = docData.get('acl', null);
      let permissions = acl != null ? acl.get('permissions', []) : [];
      let userId = request.auth.uid;
      let userRole = getUserData().role;

      // If no ACL, return false; otherwise check permissions
      return acl != null && permissions.size() > 0 && (
        // User-based permission
        permissions.hasAny([{
          'principalType': 'user',
          'principalId': userId,
          'access': requiredAccess
        }]) ||
        permissions.hasAny([{
          'principalType': 'user',
          'principalId': userId,
          'access': 'admin'
        }]) ||
        // Role-based permission
        permissions.hasAny([{
          'principalType': 'role',
          'principalId': userRole,
          'access': requiredAccess
        }]) ||
        permissions.hasAny([{
          'principalType': 'role',
          'principalId': userRole,
          'access': 'admin'
        }])
      );
    }

    // Check if user is document owner
    function isDocumentOwner(docData) {
      return docData.get('ownerId', null) == request.auth.uid;
    }

    // --- LEGAL HOLD HELPERS (Story 25.2) ---
    // Check if a document is under legal hold
    function isDocumentUnderLegalHold(docData) {
      return docData.get('isUnderHold', false) == true ||
             (docData.get('legalHoldIds', []).size() > 0);
    }

    // Check if document can be deleted (not under legal hold)
    function canDeleteDocumentSafely(docData) {
      return !isDocumentUnderLegalHold(docData);
    }

    // Combined document access check
    // Returns true if user can read the document based on:
    // 1. Being admin/RSSI (always has access)
    // 2. Being document owner
    // 3. Classification-based access (when ACL defaultAccess is 'classification')
    // 4. Explicit ACL permission
    function canAccessDocument(docData) {
      let userRole = getUserData().role;
      let acl = docData.get('acl', null);
      let defaultAccess = acl != null ? acl.get('defaultAccess', 'classification') : 'classification';

      // Admin and RSSI always have access, OR document owner always has access
      // OR check based on defaultAccess mode
      return userRole in ['admin', 'super_admin', 'rssi'] ||
             isDocumentOwner(docData) ||
             (defaultAccess == 'classification' && canAccessDocumentClassification(docData)) ||
             (defaultAccess != 'classification' && hasExplicitAclPermission(docData, 'read'));
    }

    // Check if user can edit document (requires edit or admin permission)
    function canEditDocument(docData) {
      let userRole = getUserData().role;

      // Admin and RSSI can always edit, OR document owner can always edit,
      // OR check explicit ACL for edit permission
      return userRole in ['admin', 'super_admin', 'rssi'] ||
             isDocumentOwner(docData) ||
             hasExplicitAclPermission(docData, 'edit');
    }

    // --- PERMISSION LOGIC ---

    // READ: Everyone in the org can read most resources
    function canRead(orgId) {
      return belongsToOrganization(orgId);
    }
    
    // WRITE (Create/Update): 
    // - Admin/RSSI: Full access
    // - Owner: Full access (via Admin role usually, but explicit check adds safety)
    // - Auditor: Can update specific resources (Audit, Document, Risk, etc.)
    // - Project Manager: Can update Projects
    function canWrite(orgId) {
      return (belongsToOrganization(orgId) && (isAdmin() || isRSSI())) || 
             isOrgOwner(orgId);
    }
    
    // DELETE:
    // - Admin/RSSI/Owner ONLY
    function canDelete(orgId) {
      return (belongsToOrganization(orgId) && (isAdmin() || isRSSI())) || 
             isOrgOwner(orgId);
    }

    // --- COLLECTIONS ---

    // Organizations
    match /organizations/{orgId} {
      // Read: Members or Owner or Super Admin
      allow read: if isSuperAdmin() || belongsToOrganization(orgId) || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
      // Create: Authenticated users (Onboarding)
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      // Update: Owner or Admin of that org
      allow update: if belongsToOrganization(orgId) && (isAdmin() || resource.data.ownerId == request.auth.uid)
        && (!('subscription' in request.resource.data) || request.resource.data.subscription == resource.data.subscription);
      // Delete: Owner ONLY (via special process usually, but allowed here for consistency)
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;

      // Integrations Subcollection
      match /integrations/{integrationId} {
        allow read: if belongsToOrganization(orgId);
        allow write: if belongsToOrganization(orgId) && isAdmin();
      }

      // Modules (Crisis, War Room, etc.)
      match /modules/{moduleId} {
        allow read: if belongsToOrganization(orgId) || isSuperAdmin();
        allow write: if isSuperAdmin() || 
          (belongsToOrganization(orgId) && (isOrgAdmin() || isRSSI() || isOrgOwner(orgId) || hasRole('direction')));
      }

      // ===========================================================================
      // EBIOS Risk Manager (Subcollections)
      // ===========================================================================

      // EBIOS Analyses
      match /ebiosAnalyses/{analysisId} {
        allow read: if canRead(orgId);
        allow create: if isAuthenticated() &&
          request.resource.data.organizationId == orgId &&
          (canWrite(orgId) || ((isAuditor() || isProjectManager()) && belongsToOrganization(orgId))) &&
          isValidString(request.resource.data.name, 1, 200);
        allow update: if (canWrite(orgId) || ((isAuditor() || isProjectManager()) && belongsToOrganization(orgId))) && request.resource.data.organizationId == resource.data.organizationId;
        // Delete allowed for admins/owners via UI
        allow delete: if canDelete(orgId);
      }

      // EBIOS Risk Sources (Custom)
      match /riskSources/{sourceId} {
        allow read: if canRead(orgId);
        allow create: if isAuthenticated() && canWrite(orgId);
        allow update: if canWrite(orgId);
        allow delete: if canDelete(orgId);
      }

      // EBIOS Targeted Objectives (Custom)
      match /targetedObjectives/{objectiveId} {
        allow read: if canRead(orgId);
        allow create: if isAuthenticated() && canWrite(orgId);
        allow update: if canWrite(orgId);
        allow delete: if canDelete(orgId);
      }

      // SMSI Program (ISO 27003)
      match /smsiProgram/{programId} {
        allow read: if canRead(orgId);
        allow write: if canWrite(orgId) || (isProjectManager() && belongsToOrganization(orgId));

        match /milestones/{milestoneId} {
          allow read: if canRead(orgId);
          allow write: if canWrite(orgId) || (isProjectManager() && belongsToOrganization(orgId));
        }
      }

      // Risk Context (ISO 27005)
      match /riskContext/{contextId} {
        allow read: if canRead(orgId);
        allow write: if canWrite(orgId);
      }

      // Control Assessments (ISO 27002 / Maturity)
      match /controlAssessments/{assessmentId} {
        allow read: if canRead(orgId);
        allow write: if canWrite(orgId);
      }

      // ===========================================================================
      // AGENTS - Endpoint Compliance Agents (Sentinel Agent)
      // ===========================================================================

      // Agents Subcollection
      // Agents are created/updated by Cloud Functions (Admin SDK) via agent API
      // Frontend can read agents for management UI
      match /agents/{agentId} {
        allow read: if canRead(orgId);
        // Create/Update/Delete handled by Cloud Functions via agent API
        allow create: if false;
        allow update: if canWrite(orgId); // Allow admin to update config via frontend
        allow delete: if canDelete(orgId); // Allow admin to delete via frontend

        // Agent Results (Check results)
        match /results/{resultId} {
          allow read: if canRead(orgId);
          allow write: if false; // Only Cloud Functions (agent API) can write
        }

        // Agent Commands (Pending commands)
        match /commands/{commandId} {
          allow read: if canRead(orgId);
          allow create: if canWrite(orgId); // Admin can send commands
          allow update: if false; // Only Cloud Functions can update
          allow delete: if canWrite(orgId);
        }

        // Agent Logs (written by Cloud Functions via agent API)
        match /logs/{logId} {
          allow read: if canRead(orgId);
          allow write: if false;
        }

        // Agent Diagnostics (written by Cloud Functions via agent API)
        match /diagnostics/{diagId} {
          allow read: if canRead(orgId);
          allow write: if false;
        }

        // Agent Network Snapshots (written by Cloud Functions via agent API)
        match /networkSnapshots/{snapId} {
          allow read: if canRead(orgId);
          allow write: if false;
        }

        // Agent Metrics History (written by Cloud Functions via agent API)
        match /metrics_history/{metricId} {
          allow read: if canRead(orgId);
          allow write: if false;
        }

        // Agent Credentials (restricted to admin/rssi only)
        // Note: clientKey, clientCertificate, serverCertificate on the agent doc
        // should be migrated here for field-level security
        match /credentials/{credId} {
          allow read: if canWrite(orgId); // Only admin/manager
          allow write: if false;
        }
      }

      // Enrollment Tokens Subcollection
      // Tokens are created/managed by Cloud Functions
      // Frontend can read tokens for management UI
      match /enrollmentTokens/{tokenId} {
        allow read: if canRead(orgId);
        // Create/Revoke handled by Cloud Functions
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }

      // Software Inventory Subcollection
      // Populated by Cloud Functions when agents upload software data
      // Frontend reads for the software inventory tab
      match /softwareInventory/{softwareId} {
        allow read: if canRead(orgId);
        // Created/Updated by Cloud Functions (Admin SDK) via agent API
        allow create: if false;
        allow update: if canWrite(orgId); // Allow admin to update authorization status
        allow delete: if canDelete(orgId);
      }

      // CIS Baselines Subcollection
      // Populated by Cloud Functions when agents upload CIS benchmark results
      match /cisBaselines/{baselineId} {
        allow read: if canRead(orgId);
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }

      // Agent Groups Subcollection
      // Groups organize agents and link to policies
      match /agentGroups/{groupId} {
        allow read: if canRead(orgId);
        allow create: if canWrite(orgId);
        allow update: if canWrite(orgId);
        allow delete: if canDelete(orgId);
      }

      // Agent Policies Subcollection
      // Policies define configuration and rules for agent groups
      match /agentPolicies/{policyId} {
        allow read: if canRead(orgId);
        allow create: if canWrite(orgId);
        allow update: if canWrite(orgId);
        allow delete: if canDelete(orgId);
      }

      // Software Authorization Requests
      // Users request authorization for software, admins review
      match /softwareAuthRequests/{requestId} {
        allow read: if canRead(orgId);
        allow create: if belongsToOrganization(orgId);
        allow update: if canWrite(orgId);
        allow delete: if canDelete(orgId);
      }

      // Policy History Subcollection
      // Tracks policy changes over time
      match /policyHistory/{historyId} {
        allow read: if canRead(orgId);
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }

      // Agent Vulnerability Tracking
      match /agentVulnerabilities/{vulnId} {
        allow read: if canRead(orgId);
        allow write: if false; // Cloud Functions only
      }

      // Vulnerability Correlations
      match /vulnerabilityCorrelations/{corrId} {
        allow read: if canRead(orgId);
        allow write: if false;
      }

      // Agent Anomaly Detection
      match /agentAnomalies/{anomalyId} {
        allow read: if canRead(orgId);
        allow write: if false;
      }

      // Agent Baselines (behavioral)
      match /agentBaselines/{baselineId} {
        allow read: if canRead(orgId);
        allow write: if false;
      }

      // Anomaly Thresholds (admin configurable)
      match /anomalyThresholds/{thresholdId} {
        allow read: if canRead(orgId);
        allow create: if canWrite(orgId);
        allow update: if canWrite(orgId);
        allow delete: if canDelete(orgId);
      }

      // Agent Reports
      match /agentReports/{reportId} {
        allow read: if canRead(orgId);
        allow write: if false;
      }

      // Report Schedules (admin configurable)
      match /reportSchedules/{scheduleId} {
        allow read: if canRead(orgId);
        allow create: if canWrite(orgId);
        allow update: if canWrite(orgId);
        allow delete: if canDelete(orgId);
      }

      // Report Templates
      match /reportTemplates/{templateId} {
        allow read: if canRead(orgId);
        allow write: if false;
      }

      // Network Alerts
      match /networkAlerts/{alertId} {
        allow read: if canRead(orgId);
        allow write: if false;
      }

      // Security Events
      match /securityEvents/{eventId} {
        allow read: if canRead(orgId);
        allow write: if false;
      }

      // Audit Logs (org-scoped)
      match /auditLogs/{logId} {
        allow read: if canRead(orgId);
        allow write: if false;
      }
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        request.auth.uid == userId || 
        belongsToOrganization(resource.data.organizationId)
      );
      
      // CREATE: Only allow creation if NO role or organizationId is specified (e.g. initial auth hook)
      // OR if the user is an Admin creating a user for their org.
      allow create: if isAuthenticated() && (
        (request.auth.uid == userId && 
         !('role' in request.resource.data) && 
         !('organizationId' in request.resource.data)) ||
        (isAdmin() && request.resource.data.organizationId == getUserData().organizationId)
      );

      // UPDATE: 
      // 1. Self-update: Can update profile fields (displayName, photoURL, theme, etc.)
      //    BUT CANNOT update 'role', 'organizationId', 'organizationName'.
      // 2. Admin: Can update everything for users in their org.
      allow update: if isAuthenticated() && (
        (
          request.auth.uid == userId && 
          // Immutable fields protection
          (!('role' in request.resource.data) || request.resource.data.role == resource.data.role) &&
          (!('organizationId' in request.resource.data) || request.resource.data.organizationId == resource.data.organizationId) &&
          (!('organizationName' in request.resource.data) || request.resource.data.organizationName == resource.data.organizationName)
        ) || 
        (
          (belongsToOrganization(resource.data.organizationId) && isAdmin()) ||
          isOrgOwner(resource.data.organizationId)
        )
      );
      
      allow delete: if belongsToOrganization(resource.data.organizationId) && (isAdmin() || isOrgOwner(resource.data.organizationId));

      // User Conversations (Chat History)
      match /conversations/{conversationId} {
        allow read, write: if request.auth.uid == userId;
      }
    }
    
    // Join Requests
    match /join_requests/{requestId} {
      allow read: if isAuthenticated() && (
        request.auth.token.email == resource.data.userEmail ||
        belongsToOrganization(resource.data.organizationId)
      );
      allow create: if isAuthenticated() && 
        request.resource.data.userEmail == request.auth.token.email &&
        (!('status' in request.resource.data) || request.resource.data.status == 'pending');
      allow update: if belongsToOrganization(resource.data.organizationId) && (isAdmin() || isOrgOwner(resource.data.organizationId))
        && (!('approvedBy' in request.resource.data) || request.resource.data.approvedBy == resource.data.approvedBy || canWrite(resource.data.organizationId))
        && (!('rejectedBy' in request.resource.data) || request.resource.data.rejectedBy == resource.data.rejectedBy || canWrite(resource.data.organizationId));
      allow delete: if belongsToOrganization(resource.data.organizationId) && (isAdmin() || isOrgOwner(resource.data.organizationId));
    }

    // Invitations
    match /invitations/{invitationId} {
      allow read: if isAuthenticated() && (
        request.auth.token.email == resource.data.email ||
        belongsToOrganization(resource.data.organizationId)
      );
      allow create: if isAuthenticated() && (isAdmin() || isOrgOwner(request.resource.data.organizationId)) && request.resource.data.organizationId == getUserData().organizationId;
      // Allow invited user to update invitation status (accept/decline)
      allow update: if isAuthenticated() && request.auth.token.email == resource.data.email;
      allow delete: if isAuthenticated() && (
        ((isAdmin() || isOrgOwner(resource.data.organizationId)) && belongsToOrganization(resource.data.organizationId)) ||
        request.auth.token.email == resource.data.email
      );
    }

    // Custom Roles
    match /custom_roles/{roleId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId);
    }

    // Risk History (Immutable)
    match /risk_history/{historyId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if false;
      allow delete: if canDelete(resource.data.organizationId);
    }
    
    // Assets
    match /assets/{assetId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId) &&
        request.resource.data.createdAt is timestamp &&
        isValidString(request.resource.data.name, 1, 200) &&
        isValidAssetType(request.resource.data.type) &&
        isValidCriticality(request.resource.data.confidentiality) &&
        isValidCriticality(request.resource.data.integrity) &&
        isValidCriticality(request.resource.data.availability) &&
        (!('description' in request.resource.data) || isValidString(request.resource.data.description, 0, 5000));

      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId &&
        (!('name' in request.resource.data) || isValidString(request.resource.data.name, 1, 200)) &&
        isValidAssetType(request.resource.data.type) &&
        isValidCriticality(request.resource.data.confidentiality) &&
        isValidCriticality(request.resource.data.integrity) &&
        isValidCriticality(request.resource.data.availability) &&
        (!('description' in request.resource.data) || isValidString(request.resource.data.description, 0, 5000));
      // DELETE: Blocked client-side to enforce integrity checks via Cloud Function 'deleteResource'
      allow delete: if false;

      match /maintenance/{maintenanceId} {
        allow read: if canRead(get(/databases/$(database)/documents/assets/$(assetId)).data.organizationId);
        allow write: if canWrite(get(/databases/$(database)/documents/assets/$(assetId)).data.organizationId);
      }
    }
    
    // Risks
    match /risks/{riskId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId) &&
        request.resource.data.createdAt is timestamp &&
        (!('threat' in request.resource.data) || isValidString(request.resource.data.threat, 1, 500)) &&
        (!('description' in request.resource.data) || isValidString(request.resource.data.description, 0, 5000)) &&
        // Hardening
        (!('probability' in request.resource.data) || isValidRiskLevel(request.resource.data.probability)) &&
        (!('impact' in request.resource.data) || isValidRiskLevel(request.resource.data.impact)) &&
        (!('status' in request.resource.data) || isValidRiskStatus(request.resource.data.status)) &&
        (!('strategy' in request.resource.data) || isValidRiskStrategy(request.resource.data.strategy));

      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId &&
        (!('createdAt' in request.resource.data.diff(resource.data).affectedKeys()) || request.resource.data.createdAt == resource.data.createdAt) &&
        (!('createdBy' in request.resource.data.diff(resource.data).affectedKeys()) || request.resource.data.createdBy == resource.data.createdBy) &&
        (!('threat' in request.resource.data) || isValidString(request.resource.data.threat, 1, 500)) &&
        (!('description' in request.resource.data) || isValidString(request.resource.data.description, 0, 5000)) &&
        // Hardening
        (!('probability' in request.resource.data) || isValidRiskLevel(request.resource.data.probability)) &&
        (!('impact' in request.resource.data) || isValidRiskLevel(request.resource.data.impact)) &&
        (!('status' in request.resource.data) || isValidRiskStatus(request.resource.data.status)) &&
        (!('strategy' in request.resource.data) || isValidRiskStrategy(request.resource.data.strategy));

      allow delete: if false;
    }

    // Vulnerabilities
    match /vulnerabilities/{vulnId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId);
    }

    // Threat Intelligence (Global/Shared)
    // NOTE: Uses sourceOrgId (not organizationId) because relationships connect entities
    // across organizations in certifier/partner scenarios. sourceOrgId identifies the
    // organization that owns/created the relationship for tenant isolation.
    match /relationships/{relId} {
      allow read: if isAuthenticated() && belongsToOrganization(resource.data.sourceOrgId);
      allow create: if isAuthenticated() && canWrite(request.resource.data.sourceOrgId);
      allow update: if isAuthenticated() && canWrite(resource.data.sourceOrgId);
      allow delete: if isAuthenticated() && canWrite(resource.data.sourceOrgId);
    }

    match /threats/{threatId} {
      // READ: Allow if belongs to user's org, OR if global (no orgId) only for super-admins
      // SECURITY: Global threats (without organizationId) are system-level and should only
      // be accessible to super-admins to prevent information leakage
      allow read: if isAuthenticated() && (
        ('organizationId' in resource.data && belongsToOrganization(resource.data.organizationId)) ||
        (!('organizationId' in resource.data) && isSuperAdmin())
      );
      
      // CREATE: Allow if creating for own org
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        (canWrite(request.resource.data.organizationId) || (isAuditor() && belongsToOrganization(request.resource.data.organizationId))); // Allow auditors to seed? Maybe. Let's stick to canWrite (Admin/Owner/RSSI)

      // UPDATE/DELETE: Org owner/admin only
      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId);
      
      // SuperAdmin write: Must still enforce tenant isolation for org-scoped threats.
      // Global threats (no organizationId) can only be written by super admins.
      allow write: if isAuthenticated() && isSuperAdmin() && (
        !('organizationId' in request.resource.data) || belongsToOrganization(request.resource.data.organizationId)
      );
    }
    
    // Controls
    match /controls/{controlId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        request.resource.data.createdAt is timestamp &&
        canWrite(request.resource.data.organizationId);
      allow update: if (canWrite(resource.data.organizationId) || (isProjectManager() && belongsToOrganization(resource.data.organizationId))) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if false;
    }

    // Suppliers
    match /suppliers/{supplierId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        request.resource.data.createdAt is timestamp &&
        canWrite(request.resource.data.organizationId) &&
        // Hardening
        (!('category' in request.resource.data) || isValidSupplierCategory(request.resource.data.category)) &&
        (!('criticality' in request.resource.data) || isValidCriticality(request.resource.data.criticality));

      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId &&
        // Hardening
        (!('category' in request.resource.data) || isValidSupplierCategory(request.resource.data.category)) &&
        (!('criticality' in request.resource.data) || isValidCriticality(request.resource.data.criticality));

      allow delete: if false;
    }

    // ICT Providers (DORA Art. 28 - Story 35.1)
    // DORA ICT Register for financial institutions
    match /ict_providers/{providerId} {
      allow read: if canRead(resource.data.organizationId);

      // CREATE: Admin/RSSI/Direction can create ICT providers
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        (canWrite(request.resource.data.organizationId) || (hasRole('direction') && belongsToOrganization(request.resource.data.organizationId))) &&
        // Validation: name and category required
        isValidString(request.resource.data.name, 1, 200) &&
        request.resource.data.category in ['critical', 'important', 'standard'];

      // UPDATE: Admin/RSSI/Direction can update
      allow update: if (canWrite(resource.data.organizationId) || (hasRole('direction') && belongsToOrganization(resource.data.organizationId))) &&
        request.resource.data.organizationId == resource.data.organizationId &&
        // Validation
        (!('name' in request.resource.data) || isValidString(request.resource.data.name, 1, 200)) &&
        (!('category' in request.resource.data) || request.resource.data.category in ['critical', 'important', 'standard']);

      // DELETE: Blocked client-side (use Cloud Functions for safe deletion)
      allow delete: if false;
    }

    // Business Processes
    match /business_processes/{processId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if false;
    }

    // Processing Activities
    match /processing_activities/{activityId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId) &&
        // Hardening
        (!('status' in request.resource.data) || isValidProcessingActivityStatus(request.resource.data.status)) &&
        (!('legalBasis' in request.resource.data) || isValidLegalBasis(request.resource.data.legalBasis));

      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId &&
        // Hardening
        (!('status' in request.resource.data) || isValidProcessingActivityStatus(request.resource.data.status)) &&
        (!('legalBasis' in request.resource.data) || isValidLegalBasis(request.resource.data.legalBasis));

      allow delete: if false;
    }

    // Privacy Requests (DSR)
    match /privacy_requests/{requestId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId);
    }

    // BCP Drills
    match /bcp_drills/{drillId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId);
    }

    // BCP Strategies
    match /bcp_strategies/{strategyId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId);
    }

    // War Room Sessions
    match /war_room_sessions/{sessionId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId);
    }

    // Recovery Plans (PRA)
    match /recovery_plans/{planId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId);
    }

    // TLPT Campaigns
    match /tlpt_campaigns/{campaignId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        (canWrite(request.resource.data.organizationId) || (isAuditor() && belongsToOrganization(request.resource.data.organizationId)));
      allow update: if (canWrite(resource.data.organizationId) || (isAuditor() && belongsToOrganization(resource.data.organizationId))) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId);
    }

    // Threat Library (Custom Threats)
    match /threat_library/{threatId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId);
    }

    // Incidents
    match /incidents/{incidentId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        request.resource.data.createdAt is timestamp &&
        (canWrite(request.resource.data.organizationId) || (isUser() && belongsToOrganization(request.resource.data.organizationId)) || (isAuditor() && belongsToOrganization(request.resource.data.organizationId))) &&
        (!('title' in request.resource.data) || isValidString(request.resource.data.title, 1, 200)) &&
        (!('description' in request.resource.data) || isValidString(request.resource.data.description, 0, 5000)) &&
        (!('status' in request.resource.data) || isValidIncidentStatus(request.resource.data.status)) &&
        (!('severity' in request.resource.data) || isValidCriticality(request.resource.data.severity)); // Users can report incidents
      allow update: if (canWrite(resource.data.organizationId) || (isAuditor() && belongsToOrganization(resource.data.organizationId))) &&
        request.resource.data.organizationId == resource.data.organizationId &&
        (!('title' in request.resource.data) || isValidString(request.resource.data.title, 1, 200)) &&
        (!('description' in request.resource.data) || isValidString(request.resource.data.description, 0, 5000)) &&
        (!('status' in request.resource.data) || isValidIncidentStatus(request.resource.data.status)) &&
        (!('severity' in request.resource.data) || isValidCriticality(request.resource.data.severity));
      allow delete: if false;

      // War Room Messages Subcollection
      // SECURITY FIX: Added organization check and userId verification for message creation
      match /war_room_messages/{msgId} {
        allow read: if canRead(get(/databases/$(database)/documents/incidents/$(incidentId)).data.organizationId);
        // SECURITY: Only allow message creation if:
        // 1. User belongs to the incident's organization
        // 2. The message userId matches the authenticated user (prevents spoofing)
        allow create: if isAuthenticated() &&
          belongsToOrganization(get(/databases/$(database)/documents/incidents/$(incidentId)).data.organizationId) &&
          request.resource.data.userId == request.auth.uid;
        allow update: if false; // Immutable chat
        allow delete: if false;
      }
    }

    // Audits
    match /audits/{auditId} {
      allow read: if canRead(resource.data.organizationId) ||
        (isAuthenticated() && belongsToOrganization(resource.data.organizationId) && "collaborators" in resource.data && resource.data.collaborators.hasAny([request.auth.uid])) ||
        (isAuthenticated() && "externalAuditors" in resource.data && resource.data.externalAuditors.hasAny([request.auth.token.email]));
        
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        request.resource.data.createdAt is timestamp &&
        (canWrite(request.resource.data.organizationId) || (isAuditor() && belongsToOrganization(request.resource.data.organizationId)));

      // UPDATE: Restrict auditor write access - only allow status updates, not full modifications
      allow update: if (canWrite(resource.data.organizationId) ||
        (isAuditor() && belongsToOrganization(resource.data.organizationId) &&
         request.resource.data.keys().hasAll(['status', 'updatedBy', 'updatedAt']) &&
         request.resource.data.size() == 3) ||
        (isAuthenticated() && belongsToOrganization(resource.data.organizationId) && "collaborators" in resource.data && resource.data.collaborators.hasAny([request.auth.uid])) ||
        (isAuthenticated() && "externalAuditors" in resource.data && resource.data.externalAuditors.hasAny([request.auth.token.email]))) &&
        request.resource.data.organizationId == resource.data.organizationId;
        
      allow delete: if canDelete(resource.data.organizationId);
    }

    // Evidence Requests
    match /evidence_requests/{requestId} {
      allow read: if canRead(resource.data.organizationId) ||
        (isAuthenticated() && belongsToOrganization(resource.data.organizationId) &&
          exists(/databases/$(database)/documents/audits/$(resource.data.auditId)) &&
          "collaborators" in get(/databases/$(database)/documents/audits/$(resource.data.auditId)).data && get(/databases/$(database)/documents/audits/$(resource.data.auditId)).data.collaborators.hasAny([request.auth.uid])
        ) ||
        (isAuthenticated() &&
          exists(/databases/$(database)/documents/audits/$(resource.data.auditId)) &&
          "externalAuditors" in get(/databases/$(database)/documents/audits/$(resource.data.auditId)).data && get(/databases/$(database)/documents/audits/$(resource.data.auditId)).data.externalAuditors.hasAny([request.auth.token.email])
        );
        
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        (
          canWrite(request.resource.data.organizationId) ||
          (isAuditor() && belongsToOrganization(request.resource.data.organizationId)) ||
          (
            exists(/databases/$(database)/documents/audits/$(request.resource.data.auditId)) &&
            (
              ("collaborators" in get(/databases/$(database)/documents/audits/$(request.resource.data.auditId)).data && get(/databases/$(database)/documents/audits/$(request.resource.data.auditId)).data.collaborators.hasAny([request.auth.uid])) ||
              ("externalAuditors" in get(/databases/$(database)/documents/audits/$(request.resource.data.auditId)).data && get(/databases/$(database)/documents/audits/$(request.resource.data.auditId)).data.externalAuditors.hasAny([request.auth.token.email]))
            )
          )
        );
        
      allow update: if (canWrite(resource.data.organizationId) ||
        (isAuditor() && belongsToOrganization(resource.data.organizationId)) ||
        (isAuthenticated() && belongsToOrganization(resource.data.organizationId) &&
          exists(/databases/$(database)/documents/audits/$(resource.data.auditId)) &&
          "collaborators" in get(/databases/$(database)/documents/audits/$(resource.data.auditId)).data && get(/databases/$(database)/documents/audits/$(resource.data.auditId)).data.collaborators.hasAny([request.auth.uid])
        ) ||
        (isAuthenticated() &&
          exists(/databases/$(database)/documents/audits/$(resource.data.auditId)) &&
          "externalAuditors" in get(/databases/$(database)/documents/audits/$(resource.data.auditId)).data && get(/databases/$(database)/documents/audits/$(resource.data.auditId)).data.externalAuditors.hasAny([request.auth.token.email])
        )) &&
        request.resource.data.organizationId == resource.data.organizationId;
        
      allow delete: if canDelete(resource.data.organizationId);
    }

    // Documents (with Classification-based RBAC - Story 24.3)
    match /documents/{documentId} {
      // READ: User must belong to org AND have classification access
      // Classification check: public=all, internal=authenticated, confidential=manager+, secret=rssi/admin
      allow read: if belongsToOrganization(resource.data.organizationId) &&
        canAccessDocument(resource.data);

      // CREATE: User must belong to org, have write permission, and be able to set the classification
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        request.resource.data.createdAt is timestamp &&
        (canWrite(request.resource.data.organizationId) || ((isAuditor() || isProjectManager()) && belongsToOrganization(request.resource.data.organizationId))) &&
        // Validate classification if provided
        (!('classification' in request.resource.data) ||
          (isValidClassification(request.resource.data.classification.level) &&
           canAccessClassificationLevel(request.resource.data.classification.level, getUserData().role)));

      // UPDATE: User must have edit access to document (classification or ACL based)
      // Also validate classification change if applicable
      // Documents under legal hold have restricted updates (Story 25.2)
      allow update: if belongsToOrganization(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId &&
        canEditDocument(resource.data) &&
        // If document is under legal hold, only allow non-critical updates
        // Critical fields protected: url, storagePath, encryption, hash, content
        (!isDocumentUnderLegalHold(resource.data) ||
          (
            // Allow metadata updates only on held documents
            (!('url' in request.resource.data) || request.resource.data.url == resource.data.get('url', null)) &&
            (!('storagePath' in request.resource.data) || request.resource.data.storagePath == resource.data.get('storagePath', null)) &&
            (!('content' in request.resource.data) || request.resource.data.content == resource.data.get('content', null)) &&
            (!('hash' in request.resource.data) || request.resource.data.hash == resource.data.get('hash', null)) &&
            // Preserve legal hold fields (only legalHoldService can modify these)
            (!('legalHoldIds' in request.resource.data) ||
              (isAdmin() || isRSSI()))
          )
        ) &&
        // If changing classification, validate the new level
        (!('classification' in request.resource.data) ||
          !('level' in request.resource.data.classification) ||
          request.resource.data.classification.level == resource.data.get('classification', {}).get('level', 'internal') ||
          (isValidClassification(request.resource.data.classification.level) &&
           canAccessClassificationLevel(request.resource.data.classification.level, getUserData().role)));

      // DELETE: Blocked client-side (use Cloud Functions for safe deletion with cascade)
      // Note: Documents under legal hold CANNOT be deleted even via Cloud Functions
      allow delete: if false;
    }

    // Audit Checklists
    match /audit_checklists/{checklistId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        (canWrite(request.resource.data.organizationId) || (isAuditor() && belongsToOrganization(request.resource.data.organizationId)));
      allow update: if (canWrite(resource.data.organizationId) || (isAuditor() && belongsToOrganization(resource.data.organizationId))) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId);
    }

    // Findings
    match /findings/{findingId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        (canWrite(request.resource.data.organizationId) || (isAuditor() && belongsToOrganization(request.resource.data.organizationId)));
      allow update: if (canWrite(resource.data.organizationId) || (isAuditor() && belongsToOrganization(resource.data.organizationId))) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId);
    }

    // Projects
    match /projects/{projectId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        request.resource.data.createdAt is timestamp &&
        (canWrite(request.resource.data.organizationId) || isProjectManager()) &&
        (!('name' in request.resource.data) || isValidString(request.resource.data.name, 1, 200)) &&
        (!('description' in request.resource.data) || isValidString(request.resource.data.description, 0, 5000));
      allow update: if (canWrite(resource.data.organizationId) || (isProjectManager() && belongsToOrganization(resource.data.organizationId))) &&
        request.resource.data.organizationId == resource.data.organizationId &&
        (!('name' in request.resource.data) || isValidString(request.resource.data.name, 1, 200)) &&
        (!('description' in request.resource.data) || isValidString(request.resource.data.description, 0, 5000));
      allow delete: if false;
    }

    // Project Milestones
    match /project_milestones/{milestoneId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        (canWrite(request.resource.data.organizationId) || (isProjectManager() && belongsToOrganization(request.resource.data.organizationId)));
      allow update: if (canWrite(resource.data.organizationId) || (isProjectManager() && belongsToOrganization(resource.data.organizationId))) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId) || (isProjectManager() && belongsToOrganization(resource.data.organizationId));
    }

    // Actions
    match /actions/{actionId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        (canWrite(request.resource.data.organizationId) || (isProjectManager() && belongsToOrganization(request.resource.data.organizationId)));
      // Allow update by Admin/Owner/PM OR the assignee (e.g. to mark as complete)
      allow update: if (canWrite(resource.data.organizationId) ||
        (isProjectManager() && belongsToOrganization(resource.data.organizationId)) ||
        (isAuthenticated() && resource.data.assigneeId == request.auth.uid && belongsToOrganization(resource.data.organizationId))) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId) || (isProjectManager() && belongsToOrganization(resource.data.organizationId));
    }
    
    // System Logs (Immutable)
    match /system_logs/{logId} {
      allow read: if canRead(resource.data.organizationId);
      // Allow creation by authenticated users for their organization to support client-side audit logging
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        request.resource.data.userId == request.auth.uid &&
        isValidString(request.resource.data.action, 1, 100) &&
        isValidString(request.resource.data.resource, 1, 100) &&
        (!('details' in request.resource.data) || isValidString(request.resource.data.details, 0, 5000));
      allow update: if false;
      allow delete: if false;
    }
    
    // Dashboard Summaries
    match /dashboard_summaries/{orgId} {
      allow read: if belongsToOrganization(orgId);
      allow write: if canWrite(orgId);
    }

    // Stats History
    // SECURITY: Restricted creation to admin/RSSI roles via canWrite
    match /stats_history/{statId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if false;
      allow delete: if false;
    }
    
    // Comments (Generic)
    match /{collection}/{docId}/comments/{commentId} {
      allow read: if canRead(get(/databases/$(database)/documents/$(collection)/$(docId)).data.organizationId);
      allow create: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/$(collection)/$(docId)).data.organizationId) &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/$(collection)/$(docId)).data.organizationId) &&
        request.auth.uid == resource.data.userId;
      allow delete: if isAuthenticated() &&
        belongsToOrganization(get(/databases/$(database)/documents/$(collection)/$(docId)).data.organizationId) && (
          request.auth.uid == resource.data.userId || 
          isAdmin() ||
          isOrgOwner(get(/databases/$(database)/documents/$(collection)/$(docId)).data.organizationId)
        );
    }
    
    // Notifications
    // SECURITY: Users can only read their own notifications (not all org notifications)
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Allow creation if:
      // 1. Authenticated
      // 2. Creating for someone in the same organization
      // 3. (Optional but good) The creator belongs to that organization
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        belongsToOrganization(request.resource.data.organizationId) &&
        request.resource.data.userId is string &&
        request.resource.data.userId.size() > 0;
      
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        (isAdmin() && belongsToOrganization(resource.data.organizationId)) ||
        isOrgOwner(resource.data.organizationId)
      );
    }

    // Backups
    // SECURITY: Auditors removed from create - auditors should have read-only access
    match /backups/{backupId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        (isAdmin() || isOrgOwner(request.resource.data.organizationId));
      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId);
    }

    // Backup Schedules
    // SECURITY: Auditors removed from create/update - auditors should have read-only access
    match /backup_schedules/{scheduleId} {
      allow read: if isAuthenticated() &&
        resource.data.organizationId == getUserData().organizationId;
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        (isAdmin() || isOrgOwner(request.resource.data.organizationId));
      allow update: if isAuthenticated() &&
        resource.data.organizationId == getUserData().organizationId &&
        (isAdmin() || isOrgOwner(resource.data.organizationId)) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId);
    }

    // Mail Queue (System)
    match /mail_queue/{mailId} {
      allow read: if false;
      allow create: if false; // Mail queue should only be populated by backend
      allow update: if false;
      allow delete: if false;
    }

    // Scheduled Emails (System)
    match /scheduled_emails/{emailId} {
      allow read: if false;
      allow create: if false; // Scheduled emails should only be created by backend
      allow update: if false;
      allow delete: if false;
    }

    // Feedback
    match /feedback/{feedbackId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow update: if false;
      allow delete: if isSuperAdmin();
    }

    // Incident Playbooks
    match /incidentPlaybooks/{playbookId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId);
    }

    // Incident Responses
    match /incidentResponses/{responseId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        (canWrite(request.resource.data.organizationId) || (isUser() && belongsToOrganization(request.resource.data.organizationId)));
      
      // SECURITY FIX: Only allow update if the user is the creator OR is an Admin/RSSI/Owner
      allow update: if (canWrite(resource.data.organizationId) ||
        (isAuthenticated() && belongsToOrganization(resource.data.organizationId) && resource.data.userId == request.auth.uid)) &&
        request.resource.data.organizationId == resource.data.organizationId;
        
      allow delete: if canDelete(resource.data.organizationId);
    }

    // Supplier Assessments
    match /supplier_assessments/{assessmentId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        (canWrite(request.resource.data.organizationId) || (isAuditor() && belongsToOrganization(request.resource.data.organizationId)));
      allow update: if (canWrite(resource.data.organizationId) || (isAuditor() && belongsToOrganization(resource.data.organizationId))) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId);
    }

    // Supplier Incidents
    match /supplier_incidents/{incidentId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && 
        request.resource.data.organizationId == getUserData().organizationId &&
        (canWrite(request.resource.data.organizationId) || (isAuditor() && belongsToOrganization(request.resource.data.organizationId)));
      allow update: if (canWrite(resource.data.organizationId) || (isAuditor() && belongsToOrganization(resource.data.organizationId))) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId);
    }

    // Partnerships (Certifier Ecosystem) - Managed by Cloud Functions
    match /partnerships/{partnershipId} {
      allow read: if belongsToOrganization(resource.data.tenantId) || 
                   (isAuthenticated() && resource.data.certifierId == getUserData().organizationId);
      allow write: if false; 
    }

    // Audit Shares (External Access Links) - Managed by Cloud Functions
    match /audit_shares/{shareId} {
      allow read: if belongsToOrganization(resource.data.organizationId);
      // External access via token is handled by Cloud Functions / backend validation
      allow write: if false; 
    }

    // Secure Storage
    match /secure_storage/{docId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId);
    }

    // ===========================================================================
    // COFFRE-FORT DOCUMENTAIRE - Legal Compliance (Epic 25)
    // ===========================================================================

    // Legal Holds Collection (Story 25.2)
    // Only admin/rssi can manage legal holds
    match /legalHolds/{holdId} {
      // Read: Org members with elevated roles can view legal holds
      allow read: if belongsToOrganization(resource.data.organizationId) &&
        (isAdmin() || isRSSI() || isAuditor());

      // Create: Only admin/rssi can create legal holds
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        (isAdmin() || isRSSI()) &&
        isValidString(request.resource.data.name, 1, 200) &&
        isValidString(request.resource.data.reason, 1, 5000) &&
        request.resource.data.status == 'active';

      // Update: Only admin/rssi can modify legal holds
      // Cannot change status from released back to active
      allow update: if belongsToOrganization(resource.data.organizationId) &&
        (isAdmin() || isRSSI()) &&
        request.resource.data.organizationId == resource.data.organizationId &&
        (!('status' in request.resource.data) ||
          request.resource.data.status == 'active' ||
          (request.resource.data.status == 'released' && resource.data.status == 'active'));

      // Delete: Only allow deletion of released holds with no documents
      allow delete: if belongsToOrganization(resource.data.organizationId) &&
        (isAdmin() || isRSSI()) &&
        resource.data.status == 'released' &&
        (resource.data.documentIds == [] || !('documentIds' in resource.data));
    }

    // Retention Policies Collection (Story 25.4)
    // Only admin/rssi can manage retention policies
    match /retentionPolicies/{policyId} {
      // Read: Org members with elevated roles can view policies
      allow read: if belongsToOrganization(resource.data.organizationId) &&
        (isAdmin() || isRSSI() || isAuditor() || isProjectManager());

      // Create: Only admin/rssi can create retention policies
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        (isAdmin() || isRSSI()) &&
        isValidString(request.resource.data.name, 1, 200) &&
        request.resource.data.retentionDays is int &&
        request.resource.data.retentionDays > 0 &&
        request.resource.data.action in ['archive', 'delete', 'notify'];

      // Update: Only admin/rssi can modify retention policies
      allow update: if belongsToOrganization(resource.data.organizationId) &&
        (isAdmin() || isRSSI()) &&
        request.resource.data.organizationId == resource.data.organizationId &&
        (!('retentionDays' in request.resource.data) ||
          (request.resource.data.retentionDays is int && request.resource.data.retentionDays > 0)) &&
        (!('action' in request.resource.data) ||
          request.resource.data.action in ['archive', 'delete', 'notify']);

      // Delete: Only admin/rssi can delete policies
      allow delete: if belongsToOrganization(resource.data.organizationId) &&
        (isAdmin() || isRSSI());
    }

    // ===========================================================================
    // DOCUMENT AUDIT TRAIL - Immutable Logs (Epic 27)
    // ===========================================================================

    // Document Audit Logs Collection (Story 27.1)
    // IMMUTABLE: Only allow create, never update or delete
    // This ensures complete audit trail integrity for compliance
    match /document_audit_logs/{logId} {
      // Read: Admin, RSSI, Auditor can read audit logs for their org
      // Regular users can read their own actions only
      allow read: if belongsToOrganization(resource.data.organizationId) &&
        (isAdmin() || isRSSI() || isAuditor() ||
         resource.data.userId == request.auth.uid);

      // Create: Only allow creation if:
      // 1. Authenticated user
      // 2. Creating for their own organization
      // 3. User ID matches the authenticated user (prevents spoofing)
      // 4. Required fields are present
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        request.resource.data.userId == request.auth.uid &&
        isValidString(request.resource.data.action, 1, 50) &&
        request.resource.data.documentId is string &&
        request.resource.data.documentId.size() > 0;

      // UPDATE: NEVER allowed - audit logs are immutable
      allow update: if false;

      // DELETE: NEVER allowed - audit logs are permanent
      allow delete: if false;
    }

    // eDiscovery Saved Searches Collection (Story 27.4)
    // Users can save and reuse search queries
    match /ediscovery_searches/{searchId} {
      // Read: Users can read their own searches, admin/rssi can read all org searches
      allow read: if belongsToOrganization(resource.data.organizationId) &&
        (isAdmin() || isRSSI() || isAuditor() || resource.data.createdBy == request.auth.uid);

      // Create: Authenticated users in org can create searches
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        request.resource.data.createdBy == request.auth.uid &&
        isValidString(request.resource.data.name, 1, 200);

      // Update: Only owner or admin can update
      allow update: if belongsToOrganization(resource.data.organizationId) &&
        (isAdmin() || isRSSI() || resource.data.createdBy == request.auth.uid) &&
        request.resource.data.organizationId == resource.data.organizationId;

      // Delete: Only owner or admin can delete
      allow delete: if belongsToOrganization(resource.data.organizationId) &&
        (isAdmin() || isRSSI() || resource.data.createdBy == request.auth.uid);
    }

    // Watermark Settings Collection (Story 27.5)
    // Organization-level watermark configuration
    match /watermark_settings/{orgId} {
      // Read: Any org member can read watermark settings
      allow read: if belongsToOrganization(orgId);

      // Write: Only admin/rssi can modify watermark settings
      allow write: if belongsToOrganization(orgId) && (isAdmin() || isRSSI());
    }

    // ===========================================================================
    // EBIOS Risk Manager (EBIOS RM) - ANSSI Methodology
    // ===========================================================================

    // EBIOS Analysis Status Validation


    // EBIOS Rules moved to organization subcollection

    // ===========================================================================
    // AUTHENTICATION SECURITY COLLECTIONS - Managed by Cloud Functions only
    // ===========================================================================

    // Auth Audit Logs - Authentication attempt history (managed by Cloud Functions)
    // SECURITY: Only super admins can read for security investigations
    match /auth_audit_logs/{logId} {
      allow read: if isSuperAdmin();
      allow write: if false; // Only Cloud Functions (Admin SDK) can write
    }

    // Auth Rate Limits - Rate limiting tokens (managed by Cloud Functions)
    // SECURITY: Never readable by clients, only writable by Cloud Functions
    match /auth_rate_limits/{limitId} {
      allow read: if false;
      allow write: if false; // Only Cloud Functions (Admin SDK) can write
    }

    // ===========================================================================
    // MISSING COLLECTION RULES - Security Hardening
    // ===========================================================================

    // Active Sessions (written by client SessionMonitoringService)
    match /active_sessions/{sessionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // WebAuthn Credentials (written by client webAuthnService)
    match /webauthn_credentials/{credId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['counter', 'lastUsedAt']);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // WebAuthn Challenges (written by client webAuthnService)
    match /webauthn_challenges/{challengeId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Security Failed Logins (written by client securityAnomalyService)
    match /security_failed_logins/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || (isAdmin() && belongsToOrganization(resource.data.organizationId)));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Security Anomalies (written by client securityAnomalyService)
    // SECURITY: Added userId verification to prevent spoofing
    match /security_anomalies/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || (isAdmin() && belongsToOrganization(resource.data.organizationId)));
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        request.resource.data.userId == request.auth.uid;
    }

    // Questionnaire Responses (written by client)
    match /questionnaire_responses/{responseId} {
      allow read: if isAuthenticated() && canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && request.resource.data.organizationId == getUserData().organizationId;
      allow update: if isAuthenticated() && canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId;
    }

    // Document Versions (written by client)
    match /document_versions/{versionId} {
      allow read: if isAuthenticated() && canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && request.resource.data.organizationId == getUserData().organizationId;
    }

    // Document Folders (written by client)
    match /document_folders/{folderId} {
      allow read: if isAuthenticated() && canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && request.resource.data.organizationId == getUserData().organizationId;
      allow update: if isAuthenticated() && canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if isAuthenticated() && canDelete(resource.data.organizationId);
    }

    // DORA Exports (written by client)
    match /dora_exports/{exportId} {
      allow read: if isAuthenticated() && canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && request.resource.data.organizationId == getUserData().organizationId;
    }

    // Frameworks (reference data - read by client, written by admin/Cloud Functions)
    match /frameworks/{frameworkId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isSuperAdmin();
    }

    // Requirements (reference data)
    match /requirements/{requirementId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isSuperAdmin();
    }

    // Control Mappings (written by client)
    match /controlMappings/{mappingId} {
      allow read: if isAuthenticated() && canRead(resource.data.organizationId);
      allow create: if isAuthenticated() && request.resource.data.organizationId == getUserData().organizationId;
      allow update: if isAuthenticated() && canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if isAuthenticated() && canDelete(resource.data.organizationId);
    }

    // Audit Logs (written by client AdminService)
    // SECURITY: Added userId verification to ensure users can only create logs attributed to themselves
    match /audit_logs/{logId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || (isAdmin() && belongsToOrganization(resource.data.organizationId)));
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        request.resource.data.userId == request.auth.uid;
    }

    // Archived Documents (created by Retention Engine Cloud Function)
    // Read-only for org members; only Cloud Functions can write
    match /archived_documents/{docId} {
      allow read: if isAuthenticated() && canRead(resource.data.organizationId);
      allow write: if false; // Only writable by Cloud Functions (Admin SDK)
    }

    // ===========================================================================
    // CMDB - Configuration Management Database (Epic CMDB)
    // ===========================================================================

    // CMDB Validation Helpers
    function isValidCIClass(val) {
      return val in ['Hardware', 'Software', 'Service', 'Document', 'Network', 'Cloud', 'Container'];
    }

    function isValidCIStatus(val) {
      return val in ['In_Stock', 'In_Use', 'In_Maintenance', 'Retired', 'Missing'];
    }

    function isValidCIEnvironment(val) {
      return val in ['Production', 'Staging', 'Development', 'Test', 'DR'];
    }

    function isValidCMDBCriticality(val) {
      return val in ['Critical', 'High', 'Medium', 'Low'];
    }

    function isValidDiscoverySource(val) {
      return val in ['Agent', 'Manual', 'Import', 'Cloud', 'Network_Scan'];
    }

    function isValidRelationshipType(val) {
      return val in ['depends_on', 'uses', 'runs_on', 'hosted_on', 'installed_on',
                     'connects_to', 'interfaces_with', 'contains', 'member_of',
                     'instance_of', 'provides', 'consumes', 'owned_by', 'supported_by'];
    }

    function isValidRelationshipStatus(val) {
      return val in ['Active', 'Inactive', 'Pending_Validation'];
    }

    // Configuration Items (CIs)
    match /cmdb_cis/{ciId} {
      // Read: Org members can read CIs
      allow read: if canRead(resource.data.organizationId);

      // Create: Admin/RSSI can create CIs
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId) &&
        isValidString(request.resource.data.name, 1, 255) &&
        isValidCIClass(request.resource.data.ciClass) &&
        isValidCIStatus(request.resource.data.status) &&
        isValidCIEnvironment(request.resource.data.environment) &&
        isValidCMDBCriticality(request.resource.data.criticality) &&
        isValidDiscoverySource(request.resource.data.discoverySource);

      // Update: Admin/RSSI can update, cannot change organizationId or ciClass
      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId &&
        request.resource.data.ciClass == resource.data.ciClass &&
        (!('name' in request.resource.data) || isValidString(request.resource.data.name, 1, 255)) &&
        (!('status' in request.resource.data) || isValidCIStatus(request.resource.data.status)) &&
        (!('environment' in request.resource.data) || isValidCIEnvironment(request.resource.data.environment)) &&
        (!('criticality' in request.resource.data) || isValidCMDBCriticality(request.resource.data.criticality));

      // Delete: Blocked (use soft delete via status=Retired)
      allow delete: if false;
    }

    // CMDB Relationships
    match /cmdb_relationships/{relId} {
      // Read: Org members can read relationships
      allow read: if canRead(resource.data.organizationId);

      // Create: Admin/RSSI can create relationships
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId) &&
        request.resource.data.sourceId != request.resource.data.targetId &&
        isValidRelationshipType(request.resource.data.relationshipType) &&
        isValidRelationshipStatus(request.resource.data.status) &&
        isValidCMDBCriticality(request.resource.data.criticality);

      // Update: Admin/RSSI can update, cannot change source/target
      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId &&
        request.resource.data.sourceId == resource.data.sourceId &&
        request.resource.data.targetId == resource.data.targetId &&
        (!('relationshipType' in request.resource.data) || isValidRelationshipType(request.resource.data.relationshipType)) &&
        (!('status' in request.resource.data) || isValidRelationshipStatus(request.resource.data.status)) &&
        (!('criticality' in request.resource.data) || isValidCMDBCriticality(request.resource.data.criticality));

      // Delete: Admin/RSSI can delete relationships
      allow delete: if canDelete(resource.data.organizationId);
    }

    // CMDB Validation Queue
    // Items pending human review for reconciliation
    match /cmdb_validation_queue/{itemId} {
      // Read: Org members can read validation queue
      allow read: if canRead(resource.data.organizationId);

      // Create: Only Cloud Functions (agent sync) - blocked for clients
      allow create: if false;

      // Update: Admin/RSSI can process validation items
      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId &&
        request.resource.data.status in ['Pending', 'Approved', 'Rejected', 'Merged', 'Expired'];

      // Delete: Admin/RSSI can remove processed items
      allow delete: if canDelete(resource.data.organizationId);
    }

    // CMDB Reconciliation Config
    // Per-organization reconciliation settings
    match /cmdb_reconciliation_config/{orgId} {
      allow read: if belongsToOrganization(orgId);
      allow write: if belongsToOrganization(orgId) && (isAdmin() || isRSSI());
    }

    // CMDB Identification Rules
    // Custom matching rules per organization
    match /cmdb_identification_rules/{ruleId} {
      allow read: if canRead(resource.data.organizationId);
      allow create: if isAuthenticated() &&
        request.resource.data.organizationId == getUserData().organizationId &&
        canWrite(request.resource.data.organizationId);
      allow update: if canWrite(resource.data.organizationId) &&
        request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if canDelete(resource.data.organizationId);
    }

    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
