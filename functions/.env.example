# ============================================================================
# Sentinel GRC - Cloud Functions Environment Variables
# Copy this file to .env and fill in your values
# ============================================================================

# SMTP Configuration for Email Sending (Legacy - prefer SendGrid)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_username
SMTP_PASS=your_password

# SendGrid Configuration (Recommended for production)
# Get your API key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx
SENDGRID_SENDER=noreply@your-domain.com

# Super Admin Configuration
# Comma-separated list of emails that have super admin privileges
# SECURITY: Keep this list minimal and rotate as needed
SUPER_ADMIN_EMAILS=admin@your-domain.com

# Stripe Configuration (for billing)
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# N8N Automation Webhook (Optional)
# URL for N8N webhook integration
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook
N8N_WEBHOOK_SECRET=your-n8n-secret

# User Secrets Encryption Key
# Generate with: openssl rand -hex 32
# Used to encrypt sensitive user data (API keys, credentials)
USER_SECRETS_ENCRYPTION_KEY=your-32-byte-hex-key

# Google Cloud Configuration
# Auto-injected by Firebase, but can be overridden
GCLOUD_PROJECT=your-project-id

# OVH API Configuration (for threat intelligence)
OVH_APPLICATION_KEY=your-app-key
OVH_APPLICATION_SECRET=your-app-secret
OVH_CONSUMER_KEY=your-consumer-key

# NVD (National Vulnerability Database) API Key
# Get from https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your-nvd-api-key

# Shodan API Key (for asset scanning)
# Get from https://account.shodan.io/
SHODAN_API_KEY=your-shodan-api-key

# Have I Been Pwned API Key
# Get from https://haveibeenpwned.com/API/Key
HIBP_API_KEY=your-hibp-api-key

# Google Safe Browsing API Key
# Get from https://console.cloud.google.com/apis/credentials
SAFE_BROWSING_API_KEY=your-safe-browsing-api-key

# ============================================================================
# IMPORTANT SECURITY NOTES:
# - Never commit this file with real values to version control
# - Use Firebase Secret Manager for sensitive values in production
# - Rotate API keys regularly
# - Restrict API key permissions to minimum required
# ============================================================================
