# SMTP Configuration for Email Sending
# Replace these values with your actual SMTP provider details (e.g., SendGrid, Mailgun, Gmail)

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_username
SMTP_PASS=your_password

# Super Admin Configuration
# Comma-separated list of emails that have super admin privileges
# SECURITY: Keep this list minimal and rotate as needed
SUPER_ADMIN_EMAILS=admin@cyber-threat-consulting.com
