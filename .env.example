# Configuration de l'application
NODE_ENV=development
PORT=3000

# Sécurité
JWT_SECRET=votre_secret_jwt_tres_long_et_securise
ENCRYPTION_KEY=votre_cle_de_chiffrement_tres_longue_et_securisee

# Base de données
DATABASE_URL=postgresql://utilisateur:motdepasse@localhost:5432/sentinel_grc

# Firebase (si utilisé)
FIREBASE_API_KEY=votre_cle_api_firebase
FIREBASE_AUTH_DOMAIN=votre-projet.firebaseapp.com
FIREBASE_PROJECT_ID=votre-projet
FIREBASE_STORAGE_BUCKET=votre-projet.appspot.com
FIREBASE_MESSAGING_SENDER_ID=votre_sender_id
FIREBASE_APP_ID=votre_app_id

# Configuration CORS (en développement)
CORS_ORIGIN=http://localhost:3000

# Configuration des logs
LOG_LEVEL=info

# Configuration du taux de limitation
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX=100  # 100 requêtes par fenêtre

# Configuration des sessions
SESSION_SECRET=votre_secret_session_securise
SESSION_COOKIE_MAX_AGE=86400000  # 1 jour en millisecondes

# Configuration des e-mails (si nécessaire)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre_email@example.com
SMTP_PASS=votre_mot_de_passe_email

# URL de l'application (utilisée pour les liens dans les e-mails)
APP_URL=http://localhost:3000

# Configuration du cache (si nécessaire)
REDIS_URL=redis://localhost:6379

# Configuration du stockage (si nécessaire)
STORAGE_PROVIDER=local  # ou 's3', 'gcs', etc.
AWS_ACCESS_KEY_ID=votre_cle_aws
AWS_SECRET_ACCESS_KEY=votre_secret_aws
AWS_REGION=eu-west-3
AWS_BUCKET_NAME=nom-de-votre-bucket

# NVD API Configuration
NVD_API_KEY=394afc4d-c77d-4bd0-8f83-28cc2593cf18
NVD_API_BASE_URL=https://services.nvd.nist.gov/rest/json
NVD_API_DELAY=6
NVD_API_RESULTS_PER_PAGE=2000
