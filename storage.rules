rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserOrg() {
      // Use custom claim for better performance and security
      return request.auth.token.organizationId;
    }
    
    function belongsToOrg(orgId) {
      return isAuthenticated() && getUserOrg() == orgId;
    }
    
    function isValidFileSize(maxSizeMB) {
      return request.resource.size < maxSizeMB * 1024 * 1024;
    }
    
    // Avatar uploads - user-specific
    match /avatars/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId && isValidFileSize(5);
    }
    
    // Documents - organization-based with Firestore lookup
    match /documents/{orgId}/{allPaths=**} {
      allow read: if belongsToOrg(orgId);
      allow write: if belongsToOrg(orgId) && isValidFileSize(10);
    }
    
    // Audit evidence - organization-based
    match /evidence/{orgId}/{allPaths=**} {
      allow read: if belongsToOrg(orgId);
      allow write: if belongsToOrg(orgId) && isValidFileSize(20);
    }
    
    // Incident attachments - organization-based
    match /incidents/{orgId}/{allPaths=**} {
      allow read: if belongsToOrg(orgId);
      allow write: if belongsToOrg(orgId) && isValidFileSize(15);
    }
    
    // Exports - organization-based, read-only after creation
    match /exports/{orgId}/{allPaths=**} {
      allow read: if belongsToOrg(orgId);
      allow create: if belongsToOrg(orgId) && isValidFileSize(50);
      allow update, delete: if false;
    }

    // Backups - organization-based
    match /backups/{orgId}/{allPaths=**} {
      allow read: if belongsToOrg(orgId);
      allow write: if belongsToOrg(orgId);
    }

    // Organizations - general storage
    match /organizations/{orgId}/{allPaths=**} {
      allow read: if belongsToOrg(orgId);
      allow write: if belongsToOrg(orgId);
    }
  }
}
