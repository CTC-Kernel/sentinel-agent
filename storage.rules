rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserOrg() {
      // Use custom claim for better performance and security
      return request.auth.token.organizationId;
    }
    
    function belongsToOrg(orgId) {
      return isAuthenticated() && getUserOrg() == orgId;
    }
    
    function isValidFileSize(maxSizeMB) {
      return request.resource.size < maxSizeMB * 1024 * 1024;
    }

    function getUserRole() {
      return request.auth.token.role;
    }
    
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.superAdmin == true;
    }

    function isAdmin() {
      return request.auth != null && (request.auth.token.role == 'admin' || request.auth.token.role == 'super_admin');
    }
    
    function isRSSI() {
      return getUserRole() == 'rssi';
    }

    function isAuditor() {
      return getUserRole() == 'auditor';
    }
    
    // Write Permission Helper
    function canWriteCritical() {
      // Backups, Org Settings
      return isAdmin() || isRSSI(); // Owner usually has 'admin' claim
    }
    
    function canWriteSensitive() {
      // Evidence, Documents
      return isAdmin() || isRSSI() || isAuditor();
    }
    
    function canWriteStandard() {
      return isAdmin() || isRSSI() || isAuditor() || getUserRole() == 'project_manager'; 
    }

    // Avatar uploads - user-specific
    // SECURITY: Fixed path traversal vulnerability by using {fileName} instead of {allPaths=**}
    match /avatars/{userId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId && isValidFileSize(5) && request.resource.contentType.matches('image/.*');
    }
    
    // Documents - Restricted write
    match /documents/{orgId}/{allPaths=**} {
      allow read: if belongsToOrg(orgId);
      allow write: if belongsToOrg(orgId) && canWriteStandard() && isValidFileSize(10) && request.resource.contentType.matches('image/.*|application/pdf|application/.*document.*|application/vnd.*|text/.*');
    }
    
    // Audit evidence - Restricted write
    match /evidence/{orgId}/{allPaths=**} {
      allow read: if belongsToOrg(orgId);
      allow write: if belongsToOrg(orgId) && canWriteSensitive() && isValidFileSize(20) && request.resource.contentType.matches('image/.*|application/pdf|application/.*document.*|application/vnd.*|text/.*');
    }
    
    // Incident attachments - Restricted write
    match /incidents/{orgId}/{allPaths=**} {
      allow read: if belongsToOrg(orgId);
      allow write: if belongsToOrg(orgId) && canWriteStandard() && isValidFileSize(15) && request.resource.contentType.matches('image/.*|application/pdf|application/.*document.*|application/vnd.*|text/.*');
    }
    
    // Exports - organization-based, read-only after creation
    match /exports/{orgId}/{allPaths=**} {
      allow read: if belongsToOrg(orgId);
      allow create: if belongsToOrg(orgId) && canWriteStandard() && isValidFileSize(50) && request.resource.contentType.matches('application/pdf|application/zip|application/.*document.*|application/vnd.*|text/csv|application/json');
      allow update, delete: if false;
    }

    // Backups - Highly Restricted
    match /backups/{orgId}/{allPaths=**} {
      allow read: if belongsToOrg(orgId) && canWriteCritical();
      allow write: if belongsToOrg(orgId) && canWriteCritical() && isValidFileSize(500) && request.resource.contentType.matches('application/json|application/zip|application/gzip|application/x-gzip'); // 500MB limit
    }

    // Organizations - General storage
    match /organizations/{orgId}/{allPaths=**} {
      allow read: if belongsToOrg(orgId);
      allow write: if belongsToOrg(orgId) && canWriteCritical() && isValidFileSize(50) && request.resource.contentType.matches('image/.*|application/pdf|application/.*document.*|application/vnd.*|text/.*'); // 50MB limit
    }

    // Agent Releases - Authenticated read for downloads, admin-only write
    // Note: Cloud Functions use signed URLs for secure downloads
    // INTENTIONAL: releases are shared across all orgs (not org-scoped).
    // These are platform-level binaries (agent installers, update packages) that are
    // identical for all organizations. Org isolation is not required here because
    // no tenant-specific data is stored in this path.
    match /releases/{allPaths=**} {
      allow read: if isAuthenticated(); // Authenticated downloads via signed URLs from Cloud Function
      allow write: if isSuperAdmin()
        && request.resource.size < 500 * 1024 * 1024
        && request.resource.contentType.matches('application/.*');
    }

    // Agent Downloads - Authenticated read for agent installers
    // INTENTIONAL: agent downloads are shared across all orgs (not org-scoped).
    // Same rationale as /releases above - platform-level binaries, no tenant data.
    match /agents/downloads/{allPaths=**} {
      allow read: if isAuthenticated(); // Authenticated downloads for agent installers
      allow write: if isSuperAdmin()
        && request.resource.size < 200 * 1024 * 1024
        && request.resource.contentType.matches('application/.*');
    }
  }
}
