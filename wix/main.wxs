<?xml version="1.0" encoding="UTF-8"?>
<!--
  Sentinel GRC Agent - Windows Installer (MSI)

  Build with WiX v4:
    dotnet tool install -g wix
    wix build -o sentinel-agent.msi main.wxs -ext WixToolset.UI.wixext -ext WixToolset.Util.wixext -ext WixToolset.Firewall.wixext

  Silent installation:
    msiexec /i sentinel-agent.msi /qn ENROLLMENTTOKEN=xxx

  With custom properties:
    msiexec /i sentinel-agent.msi /qn SERVERURL=https://api.example.com ENROLLMENTTOKEN=xxx
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:fire="http://wixtoolset.org/schemas/v4/wxs/firewall">

  <!-- Product definition -->
  <Package
    Name="Sentinel Agent"
    Manufacturer="Cyber Threat Consulting"
    Version="$(var.Version)"
    UpgradeCode="E8F3C2A1-4B5D-4E6F-8A9B-0C1D2E3F4A5B"
    Scope="perMachine"
    Compressed="yes">

    <!-- Application icon for Add/Remove Programs -->
    <Icon Id="SentinelIcon" SourceFile="$(var.AssetsDir)\sentinel-agent.ico" />
    <Property Id="ARPPRODUCTICON" Value="SentinelIcon" />
    <Property Id="ARPHELPLINK" Value="https://app.cyber-threat-consulting.com" />
    <Property Id="ARPURLINFOABOUT" Value="https://cyber-threat-consulting.com" />

    <SummaryInformation
      Description="Agent de conformité endpoint pour la plateforme Sentinel GRC"
      Manufacturer="Cyber Threat Consulting" />

    <!-- Upgrade handling - remove previous versions -->
    <MajorUpgrade
      DowngradeErrorMessage="Une version plus récente de [ProductName] est déjà installée."
      Schedule="afterInstallInitialize" />

    <!-- Embedded UI for progress during silent install -->
    <WixVariable Id="WixUILicenseRtf" Value="wix\license.rtf" />

    <!-- Custom properties for configuration -->
    <Property Id="SERVERURL" Value="https://europe-west1-sentinel-grc-a8701.cloudfunctions.net/agentApi" />
    <Property Id="ENROLLMENTTOKEN" Secure="yes" />

    <!-- UI Extension for custom dialogs -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />
    <ui:WixUI Id="WixUI_InstallDir" />

    <!-- Custom UI sequence to add enrollment dialog -->
    <UI>
      <Dialog Id="EnrollmentDlg" Width="370" Height="270" Title="Configuration de l'agent">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Configuration Sentinel Agent" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="20" Transparent="yes" NoPrefix="yes" Text="Entrez le token d'enrollment fourni par votre administrateur." />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

        <Control Id="TokenLabel" Type="Text" X="20" Y="60" Width="100" Height="15" Text="Token d'enrollment:" />
        <Control Id="TokenEdit" Type="Edit" X="20" Y="78" Width="330" Height="18" Property="ENROLLMENTTOKEN" />

        <Control Id="ServerLabel" Type="Text" X="20" Y="110" Width="100" Height="15" Text="URL du serveur:" />
        <Control Id="ServerEdit" Type="Edit" X="20" Y="128" Width="330" Height="18" Property="SERVERURL" />

        <Control Id="AutoStartCheck" Type="CheckBox" X="20" Y="160" Width="330" Height="17" Property="AUTOSTART" CheckBoxValue="1" Text="Démarrer automatiquement avec Windows" />

        <Control Id="Info" Type="Text" X="20" Y="190" Width="330" Height="30" Text="L'agent se connectera au serveur Sentinel GRC après l'installation pour vérifier la conformité de cet ordinateur." />

        <Control Id="BottomLine" Type="Line" X="0" Y="224" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="180" Y="237" Width="56" Height="17" Text="Retour">
          <Publish Event="NewDialog" Value="InstallDirDlg" />
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="237" Width="56" Height="17" Default="yes" Text="Suivant">
          <Publish Event="NewDialog" Value="VerifyReadyDlg" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="237" Width="56" Height="17" Cancel="yes" Text="Annuler">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>
      </Dialog>

      <!-- Insert enrollment dialog in sequence -->
      <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="EnrollmentDlg" Order="4" Condition="1" />
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="EnrollmentDlg" Order="1" Condition="NOT Installed" />
    </UI>

    <!-- Auto-start property default -->
    <Property Id="AUTOSTART" Value="1" />

    <!-- Prerequisite checks -->
    <Launch Condition="VersionNT64 &gt;= 603"
            Message="Sentinel Agent requiert Windows 8.1 ou Windows Server 2012 R2 (ou ulterieur)." />
    <Launch Condition="Privileged"
            Message="Droits administrateur requis. Relancez l'installation en tant qu'administrateur." />

    <!-- Media definition -->
    <Media Id="1" Cabinet="sentinel.cab" EmbedCab="yes" />

    <!-- Feature definition -->
    <Feature Id="MainFeature" Title="Sentinel Agent" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentGroupRef Id="ShortcutComponents" />
      <ComponentRef Id="AutoStartGuiComponent" />
      <ComponentGroupRef Id="ConfigComponents" />
    </Feature>

    <!-- Directory structure -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLDIR" Name="Sentinel">
        <Directory Id="BinDir" Name="bin" />
        <Directory Id="ConfigDir" Name="config" />
        <Directory Id="LogDir" Name="logs" />
        <Directory Id="DocsDir" Name="docs" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="SentinelDataDir" Name="Sentinel">
        <Directory Id="DataDir" Name="data" />
        <Directory Id="ModelsDir" Name="models" />
        <Directory Id="CacheDir" Name="cache">
          <Directory Id="CacheLlmDir" Name="llm" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- Start Menu shortcuts -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="SentinelMenuFolder" Name="Sentinel Agent" />
    </StandardDirectory>

    <!-- Desktop shortcut directory -->
    <StandardDirectory Id="DesktopFolder" />

    <!-- Product components - main binary with service registration -->
    <ComponentGroup Id="ProductComponents" Directory="BinDir">
      <Component Id="MainExecutable" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
        <File Id="SentinelAgentExe"
              Name="sentinel-agent.exe"
              Source="$(var.TargetDir)\agent-core.exe"
              KeyPath="yes" />

        <!-- GUI launcher batch file - always starts with GUI -->
        <File Id="SentinelGuiLauncher"
              Name="sentinel-agent-gui.bat"
              Source="scripts\sentinel-gui-launcher.bat" />

        <!-- Direct CMD launcher for double-click -->
        <File Id="SentinelDirectLauncher"
              Name="sentinel-agent.cmd"
              Source="scripts\sentinel-agent.cmd" />

        <!-- Windows Service registration using the same binary -->
        <ServiceInstall
          Id="SentinelServiceInstall"
          Name="SentinelGRCAgent"
          DisplayName="Sentinel Agent"
          Description="Agent de conformité endpoint pour la plateforme Sentinel GRC"
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal"
          Arguments="--service" />

        <!-- Service recovery settings using util extension -->
        <util:ServiceConfig
          ServiceName="SentinelGRCAgent"
          FirstFailureActionType="restart"
          SecondFailureActionType="restart"
          ThirdFailureActionType="restart"
          RestartServiceDelayInSeconds="60"
          ResetPeriodInDays="1" />

        <!-- Service control: stop on install/uninstall, remove on uninstall.
             Do NOT auto-start on install — the GUI handles the runtime during
             the interactive session. The service starts on next boot via Start="auto". -->
        <!-- Service control: starting the service on install ensures the background tasks and ACLs run. -->
        <ServiceControl
          Id="SentinelServiceControl"
          Name="SentinelGRCAgent"
          Start="install"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />

        <!-- Windows Firewall rule for agent communication -->
        <fire:FirewallException Id="SentinelAgentFirewall"
            Name="Sentinel GRC Agent"
            Description="Communications sortantes de l'agent Sentinel GRC"
            File="SentinelAgentExe"
            Protocol="tcp"
            Scope="any"
            Profile="all" />
      </Component>

      <!-- Icon file for shortcuts -->
      <Component Id="IconComponent" Guid="B2C3D4E5-F6A7-8901-BCDE-F23456789012">
        <File Id="AppIconFile"
              Name="sentinel-agent.ico"
              Source="$(var.AssetsDir)\sentinel-agent.ico"
              KeyPath="yes" />
      </Component>

      <!-- Event Log source registration -->
      <Component Id="EventLogSource" Guid="F1E2D3C4-B5A6-9788-7654-321098FEDCBA">
        <util:EventSource Name="SentinelGRCAgent"
            Log="Application"
            EventMessageFile="[BinDir]sentinel-agent.exe"
            KeyPath="yes" />
      </Component>

      <!-- Add to system PATH with validation -->
      <Component Id="PathEnvComponent" Guid="A9B8C7D6-E5F4-3210-FEDC-BA9876543210">
        <Environment Id="SentinelPath" Name="PATH" Value="[BinDir]"
            Permanent="yes" Part="last" Action="set" System="yes" />
        <RegistryValue Root="HKLM" Key="Software\Sentinel\Agent"
            Name="PathAdded" Type="integer" Value="1" KeyPath="yes" />
        <RegistryValue Root="HKLM" Key="Software\Sentinel\Agent\Backup"
            Name="OriginalPath" Type="string" Value="[~];[BinDir]" />
      </Component>
    </ComponentGroup>

    <!-- Shortcut components -->
    <ComponentGroup Id="ShortcutComponents">
      <!-- Start Menu folder and shortcuts -->
      <Component Id="StartMenuShortcuts" Guid="F6A7B8C9-D0E1-2345-6789-0ABCDEF12345" Directory="SentinelMenuFolder">
        <Shortcut Id="StartMenuShortcut"
                  Name="Sentinel Agent"
                  Description="Lancer l'agent de conformité Sentinel"
                  Target="[BinDir]sentinel-agent-gui.bat"
                  WorkingDirectory="BinDir"
                  Icon="SentinelIcon" />

        <Shortcut Id="DashboardShortcut"
                  Name="Tableau de bord Sentinel"
                  Description="Ouvrir le tableau de bord en ligne"
                  Target="[SystemFolder]cmd.exe"
                  Arguments='/c start https://app.cyber-threat-consulting.com/settings?tab=agents'
                  Icon="SentinelIcon" />

        <Shortcut Id="UninstallShortcut"
                  Name="Désinstaller Sentinel Agent"
                  Target="[SystemFolder]msiexec.exe"
                  Arguments="/x [ProductCode]" />

        <RemoveFolder Id="RemoveStartMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\Sentinel\Agent" Name="StartMenuInstalled" Type="integer" Value="1" KeyPath="yes" />
      </Component>

      <!-- Desktop shortcut -->
      <Component Id="DesktopShortcutComponent" Guid="A7B8C9D0-E1F2-3456-789A-BCDEF0123456" Directory="DesktopFolder">
        <Shortcut Id="DesktopShortcut"
                  Name="Sentinel Agent"
                  Description="Lancer l'agent de conformité Sentinel"
                  Target="[BinDir]sentinel-agent-gui.bat"
                  WorkingDirectory="BinDir"
                  Icon="SentinelIcon" />
        <RemoveFolder Id="RemoveDesktopShortcut" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\Sentinel\Agent"
                       Name="DesktopShortcutInstalled" Type="integer" Value="1" KeyPath="yes" />
      </Component>

      <!-- Auto-start GUI for current user at logon -->
      <Component Id="AutoStartGuiComponent" Guid="B8C9D0E1-F234-4567-89AB-CDEF01234567" Directory="BinDir">
        <RegistryKey Root="HKCU" Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Run">
          <RegistryValue Type="string" Name="SentinelAgentGUI" Value="&quot;[BinDir]sentinel-agent-gui.bat&quot;" />
        </RegistryKey>
        <RegistryValue Root="HKCU" Key="Software\Sentinel\Agent" Name="GuiAutoStart" Type="integer" Value="1" KeyPath="yes" />
      </Component>

      <!-- Note: Service auto-start is handled separately (Start="auto").
           GUI auto-start is for user session tray icon. -->
    </ComponentGroup>

    <!-- Configuration component -->
    <ComponentGroup Id="ConfigComponents" Directory="ConfigDir">
      <Component Id="ConfigFileComponent" Guid="C3D4E5F6-A7B8-9012-CDEF-345678901234">
        <File Id="DefaultConfigFile"
              Name="agent.json"
              Source="config\agent.example.json" />
      </Component>

      <!-- LLM configuration template -->
      <Component Id="LlmConfigFileComponent" Guid="C3D4E5F6-A7B8-9012-CDEF-345678901235">
        <File Id="LlmConfigFile"
              Name="llm.json"
              Source="config\llm.example.json" />
      </Component>

      <!-- Code signing certificate for TrustedPublisher auto-install -->
      <Component Id="SigningCertComponent" Guid="F7A8B9C0-D1E2-3456-7890-ABCDEF123457">
        <File Id="SigningCertFile"
              Name="sentinel-signing.cer"
              Source="sentinel-selfsigned.cer"
              KeyPath="yes" />
      </Component>

      <!-- Documentation -->
      <Component Id="DocsComponent" Guid="D4E5F6A7-B8C9-0123-DEF0-456789012346" Directory="DocsDir">
        <File Id="UserGuide"
              Name="Guide-Utilisateur.md"
              Source="docs\USER_GUIDE.md" />
      </Component>

      <!-- Create data directory with proper permissions -->
      <Component Id="DataDirComponent" Guid="D4E5F6A7-B8C9-0123-DEF0-456789012345" Directory="DataDir">
        <CreateFolder>
          <util:PermissionEx User="Users" GenericAll="yes" />
          <util:PermissionEx User="Administrators" GenericAll="yes" />
          <util:PermissionEx User="SYSTEM" GenericAll="yes" />
        </CreateFolder>
      </Component>

      <!-- Create models directory for LLM GGUF files -->
      <Component Id="ModelsDirComponent" Guid="D4E5F6A7-B8C9-0123-DEF0-456789012347" Directory="ModelsDir">
        <CreateFolder>
          <util:PermissionEx User="Users" GenericAll="yes" />
          <util:PermissionEx User="Administrators" GenericAll="yes" />
          <util:PermissionEx User="SYSTEM" GenericAll="yes" />
        </CreateFolder>
      </Component>

      <!-- Create LLM cache directory -->
      <Component Id="CacheLlmDirComponent" Guid="D4E5F6A7-B8C9-0123-DEF0-456789012348" Directory="CacheLlmDir">
        <CreateFolder>
          <util:PermissionEx User="Users" GenericAll="yes" />
          <util:PermissionEx User="Administrators" GenericAll="yes" />
          <util:PermissionEx User="SYSTEM" GenericAll="yes" />
        </CreateFolder>
      </Component>

      <!-- Create log directory -->
      <Component Id="LogDirComponent" Guid="E5F6A7B8-C9D0-1234-EF01-567890123456" Directory="LogDir">
        <CreateFolder>
          <util:PermissionEx User="Users" GenericAll="yes" />
          <util:PermissionEx User="Administrators" GenericAll="yes" />
          <util:PermissionEx User="SYSTEM" GenericAll="yes" />
        </CreateFolder>
      </Component>
    </ComponentGroup>

    <!--
      ════════════════════════════════════════════════════════════════
      Custom Actions
      ════════════════════════════════════════════════════════════════

      All install/uninstall CAs are IMMEDIATE and scheduled AFTER InstallFinalize.
      This ensures:
        1. All files are already installed (binaries, certs, configs)
        2. MSI property resolution works ([BinDir], [ENROLLMENTTOKEN], etc.)
        3. The installer process is elevated (Launch Condition: Privileged)

      The only DEFERRED CA is KillGuiProcess (uninstall) which must run
      BEFORE file removal and needs no property resolution.
    -->

    <!-- Install signing certificate into TrustedPublisher so future updates are trusted -->
    <CustomAction Id="InstallCertificate"
                  Directory="ConfigDir"
                  ExeCommand="powershell.exe -NoProfile -NonInteractive -ExecutionPolicy RemoteSigned -Command &quot;try { certutil -addstore 'TrustedPublisher' '[ConfigDir]sentinel-signing.cer' } catch { Write-EventLog -LogName Application -Source 'Sentinel Agent' -EventId 1003 -EntryType Error -Message ('Certificate installation failed: ' + $_) }&quot;"
                  Return="ignore" />

    <!-- Windows Defender exclusion -->
    <CustomAction Id="AddDefenderExclusion"
                  Directory="BinDir"
                  ExeCommand="powershell.exe -NoProfile -NonInteractive -ExecutionPolicy RemoteSigned -Command &quot;try { Add-MpPreference -ExclusionPath '[INSTALLDIR]' -ExclusionProcess '[BinDir]sentinel-agent.exe' -ErrorAction SilentlyContinue } catch { Write-EventLog -LogName Application -Source 'Sentinel Agent' -EventId 1001 -EntryType Error -Message ('Failed to add Defender exclusion: ' + $_) }&quot;"
                  Return="ignore" />

    <!-- Create config file with enrollment token in ProgramData\Sentinel -->
    <CustomAction Id="CreateConfigFile"
                  Directory="SentinelDataDir"
                  ExeCommand="cmd.exe /c mkdir &quot;[SentinelDataDir]&quot; 2>nul &amp; echo {&quot;server&quot;:{&quot;url&quot;:&quot;[SERVERURL]&quot;,&quot;token&quot;:&quot;[ENROLLMENTTOKEN]&quot;},&quot;gui&quot;:{&quot;enabled&quot;:true,&quot;autostart&quot;:true,&quot;minimize_to_tray&quot;:true}} > &quot;[SentinelDataDir]agent.json&quot;"
                  Return="ignore" />

    <!-- Run enrollment after install -->
    <CustomAction Id="RunEnrollment"
                  Directory="BinDir"
                  ExeCommand="&quot;[BinDir]sentinel-agent.exe&quot; enroll --token &quot;[ENROLLMENTTOKEN]&quot; --server &quot;[SERVERURL]&quot;"
                  Return="ignore" />

    <!-- Launch GUI after install via batch launcher (handles de-elevation).
         asyncNoWait so the installer closes immediately without waiting for the GUI. -->
    <CustomAction Id="LaunchGui"
                  Directory="BinDir"
                  ExeCommand="sentinel-agent-gui.bat"
                  Return="asyncNoWait" />

    <!-- Force kill Sentinel processes on uninstall (DEFERRED — must run before file removal).
         Only sentinel-agent.exe is installed; no other binary names to kill. -->
    <CustomAction Id="KillGuiProcess"
                  Directory="SystemFolder"
                  ExeCommand="cmd.exe /c &quot;taskkill.exe /f /im sentinel-agent.exe &amp; timeout /t 2 /nobreak &gt;nul&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- Remove Defender exclusion on uninstall -->
    <CustomAction Id="RemoveDefenderExclusion"
                  Directory="BinDir"
                  ExeCommand="powershell.exe -NoProfile -NonInteractive -ExecutionPolicy RemoteSigned -Command &quot;Remove-MpPreference -ExclusionPath '[INSTALLDIR]' -ExclusionProcess '[BinDir]sentinel-agent.exe' -ErrorAction SilentlyContinue&quot;"
                  Return="ignore" />

    <!-- Uninstall cleanup — remove ProgramData\Sentinel contents (only on full uninstall, not upgrade) -->
    <CustomAction Id="CleanupDataOnUninstall"
                  Directory="CommonAppDataFolder"
                  ExeCommand="powershell.exe -NoProfile -NonInteractive -ExecutionPolicy RemoteSigned -Command &quot;try { Remove-Item '[CommonAppDataFolder]Sentinel\*' -Recurse -Force -ErrorAction SilentlyContinue } catch { Write-EventLog -LogName Application -Source 'Sentinel Agent' -EventId 1002 -EntryType Warning -Message ('Cleanup failed: ' + $_) }&quot;"
                  Return="ignore" />

    <!-- Installation sequence -->
    <InstallExecuteSequence>
      <!--
        UNINSTALL: Kill processes BEFORE file removal (deferred, between
        InstallInitialize and InstallFinalize). No property resolution needed.
      -->
      <Custom Action="KillGuiProcess" After="InstallInitialize"
              Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE" />

      <!--
        INSTALL: All post-install actions run AFTER InstallFinalize (immediate).
        At this point files are installed and [Property] references resolve correctly.
        Order: certificate -> defender exclusion -> config -> enrollment -> launch GUI
      -->
      <Custom Action="InstallCertificate" After="InstallFinalize"
              Condition="NOT Installed" />
      <Custom Action="AddDefenderExclusion" After="InstallCertificate"
              Condition="NOT Installed" />
      <Custom Action="CreateConfigFile" After="AddDefenderExclusion"
              Condition="NOT Installed AND ENROLLMENTTOKEN" />
      <Custom Action="RunEnrollment" After="CreateConfigFile"
              Condition="NOT Installed AND ENROLLMENTTOKEN" />
      <Custom Action="LaunchGui" After="RunEnrollment"
              Condition="NOT Installed" />

      <!--
        UNINSTALL: Post-uninstall cleanup AFTER InstallFinalize (immediate).
        Properties still resolve during uninstall for the installed product.
      -->
      <Custom Action="RemoveDefenderExclusion" After="LaunchGui"
              Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE" />
      <Custom Action="CleanupDataOnUninstall" After="RemoveDefenderExclusion"
              Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE" />
    </InstallExecuteSequence>

  </Package>
</Wix>
