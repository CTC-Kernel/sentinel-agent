<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:fire="http://wixtoolset.org/schemas/v4/wxs/firewall">

  <!-- Product definition - English version -->
  <Package
    Name="Sentinel Agent"
    Manufacturer="Cyber Threat Consulting"
    Version="$(var.Version)"
    UpgradeCode="E8F3C2A1-4B5D-4E6F-8A9B-0C1D2E3F4A5B"
    Scope="perMachine"
    InstallerVersion="500"
    Compressed="yes"
    Language="1033">

    <!-- Application icon for Add/Remove Programs -->
    <Icon Id="SentinelIcon" SourceFile="$(var.AssetsDir)\icons\sentinel-agent.ico" />
    <Property Id="ARPPRODUCTICON" Value="SentinelIcon" />
    <Property Id="ARPHELPLINK" Value="https://app.cyber-threat-consulting.com" />
    <Property Id="ARPURLINFOABOUT" Value="https://cyber-threat-consulting.com" />

    <SummaryInformation
      Description="Endpoint compliance monitoring agent for Sentinel GRC platform"
      Manufacturer="Cyber Threat Consulting" />

    <!-- Upgrade handling - remove previous versions -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of [ProductName] is already installed."
      Schedule="afterInstallInitialize" />

    <!-- Embedded UI for progress during silent install -->
    <WixVariable Id="WixUILicenseRtf" Value="wix\license.rtf" />

    <!-- Custom properties for configuration -->
    <Property Id="SERVERURL" Value="https://YOUR_REGION-YOUR_FIREBASE_PROJECT_ID.cloudfunctions.net/agentApi" />
    <Property Id="ENROLLMENTTOKEN" Secure="yes" />

    <!-- UI Extension for custom dialogs -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />
    <ui:WixUI Id="WixUI_InstallDir" />

    <!-- Custom UI sequence to add enrollment dialog -->
    <UI>
      <Dialog Id="EnrollmentDlg" Width="370" Height="270" Title="Agent Configuration">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Sentinel Agent Configuration" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="20" Transparent="yes" NoPrefix="yes" Text="Enter the enrollment token provided by your administrator." />
        <Control Id="ServerLabel" Type="Text" X="25" Y="50" Width="320" Height="15" Transparent="yes" NoPrefix="yes" Text="Server URL:" />
        <Control Id="ServerEdit" Type="Edit" X="25" Y="65" Width="320" Height="18" Property="SERVERURL" />
        <Control Id="TokenLabel" Type="Text" X="25" Y="90" Width="320" Height="15" Transparent="yes" NoPrefix="yes" Text="Enrollment Token:" />
        <Control Id="TokenEdit" Type="Edit" X="25" Y="105" Width="320" Height="18" Property="ENROLLMENTTOKEN" Password="yes" />
        <Control Id="AutoStartLabel" Type="Text" X="25" Y="130" Width="320" Height="15" Transparent="yes" NoPrefix="yes" Text="Start Sentinel Agent automatically at Windows startup" />
        <Control Id="AutoStartCheckbox" Type="CheckBox" X="25" Y="145" Width="320" Height="18" Property="AUTOSTART" CheckBoxValue="1" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="Back" />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Text="Next" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Text="Cancel" />
      </Dialog>

      <!-- Insert enrollment dialog in sequence -->
      <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="EnrollmentDlg" Order="4" Condition="1" />
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="EnrollmentDlg" Order="1" Condition="NOT Installed" />
    </UI>

    <!-- Auto-start property default -->
    <Property Id="AUTOSTART" Value="1" />

    <!-- Prerequisite checks -->
    <Launch Condition="VersionNT64 >= 603"
            Message="Sentinel Agent requires Windows 8.1 or Windows Server 2012 R2 (or later)." />


    <!-- Media definition -->
    <Media Id="1" Cabinet="sentinel.cab" EmbedCab="yes" />

    <!-- Directory structure -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLDIR" Name="Sentinel">
        <Directory Id="BinDir" Name="bin" />
        <Directory Id="ConfigDir" Name="config" />
        <Directory Id="LogDir" Name="logs" />
        <Directory Id="DocsDir" Name="docs" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="SentinelDataDir" Name="Sentinel">
        <Directory Id="DataDir" Name="data" />
        <Directory Id="ModelsDir" Name="models" />
        <Directory Id="CacheDir" Name="cache">
          <Directory Id="CacheLlmDir" Name="llm" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="StartMenuDir" Name="Sentinel Agent" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <!-- Product components - main binary with service registration -->
    <ComponentGroup Id="ProductComponents" Directory="BinDir">
      <Component Id="MainExecutable" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
        <File Id="SentinelAgentExe"
              Name="sentinel-agent.exe"
              Source="$(var.TargetDir)\agent-core.exe"
              KeyPath="yes" />

        <!-- Windows Service registration using the same binary -->
        <ServiceInstall
          Id="SentinelServiceInstall"
          Name="SentinelGRCAgent"
          DisplayName="Sentinel Agent"
          Description="Endpoint compliance monitoring agent for Sentinel GRC platform"
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal"
          Arguments="--service" />

        <!-- Service control: stop on install/uninstall, remove on uninstall. -->
        <ServiceControl
          Id="SentinelServiceControl"
          Name="SentinelGRCAgent"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />

        <!-- Windows Firewall rule for outbound agent communication -->
        <fire:FirewallException Id="SentinelAgentFirewall"
            Name="Sentinel GRC Agent"
            Description="Authorize Sentinel GRC agent communications"
            File="SentinelAgentExe"
            Profile="all"
            Scope="any" />
      </Component>

      <!-- Icon file for shortcuts -->
      <Component Id="IconComponent" Guid="B2C3D4E5-F6A7-8901-BCDE-F23456789012">
        <File Id="AppIconFile"
              Name="sentinel-agent.ico"
              Source="$(var.AssetsDir)\icons\sentinel-agent.ico"
              KeyPath="yes" />
      </Component>

      <!-- Event Log source registration -->
      <Component Id="EventLogSource" Guid="F1E2D3C4-B5A6-9788-7654-321098FEDCBA">
        <util:EventSource Name="SentinelGRCAgent"
            Log="Application"
            EventMessageFile="[BinDir]sentinel-agent.exe"
            KeyPath="yes" />
      </Component>

      <!-- Add to system PATH with validation -->
      <Component Id="PathEnvComponent" Guid="A9B8C7D6-E5F4-3210-FEDC-BA9876543210">
        <Environment Id="SentinelPath" Name="PATH" Value="[BinDir]"
            Permanent="no" Part="last" Action="set" System="yes" />
        <RegistryValue Root="HKLM" Key="Software\Sentinel\Agent"
            Name="PathAdded" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Shortcut components -->
    <ComponentGroup Id="ShortcutComponents">
      <!-- Start Menu folder and shortcuts -->
      <Component Id="StartMenuShortcuts" Guid="F6A7B8C9-D0E1-2345-6789-0ABCDEF12345" Directory="StartMenuDir">
        <Shortcut Id="StartMenuShortcut"
                  Name="Sentinel Agent"
                  Description="Launch Sentinel GRC Agent"
                  Target="[BinDir]sentinel-agent.exe"
                  WorkingDirectory="BinDir"
                  Icon="SentinelIcon" />

        <Shortcut Id="DashboardShortcut"
                  Name="Sentinel Dashboard"
                  Description="Open the online dashboard"
                  Target="[WindowsFolder]explorer.exe"
                  Arguments="https://app.cyber-threat-consulting.com/settings?tab=agents"
                  Icon="SentinelIcon" />

        <Shortcut Id="UninstallShortcut"
                  Name="Uninstall Sentinel Agent"
                  Target="[SystemFolder]msiexec.exe"
                  Arguments="/x [ProductCode]" />

        <RemoveFolder Id="RemoveStartMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\Sentinel\Agent" Name="StartMenuInstalled" Type="integer" Value="1" KeyPath="yes" />
      </Component>

      <!-- Desktop shortcut -->
      <Component Id="DesktopShortcutComponent" Guid="A7B8C9D0-E1F2-3456-789A-BCDEF0123456" Directory="DesktopFolder">
        <Shortcut Id="DesktopShortcut"
                  Name="Sentinel Agent"
                  Description="Launch Sentinel GRC Agent"
                  Target="[BinDir]sentinel-agent.exe"
                  WorkingDirectory="BinDir"
                  Icon="SentinelIcon" />
        <RegistryValue Root="HKCU" Key="Software\Sentinel\Agent"
                       Name="DesktopShortcutInstalled" Type="integer" Value="1" KeyPath="yes" />
      </Component>

      <!-- Auto-start GUI for current user at logon -->
      <Component Id="AutoStartGuiComponent" Guid="B8C9D0E1-F234-4567-89AB-CDEF01234567" Directory="BinDir" Condition="AUTOSTART">
        <RegistryKey Root="HKCU" Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Run">
          <RegistryValue Type="string" Name="SentinelAgentGUI" Value="&quot;[BinDir]sentinel-agent.exe&quot;" />
        </RegistryKey>
        <RegistryValue Root="HKCU" Key="Software\Sentinel\Agent" Name="GuiAutoStart" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Feature definitions -->
    <Feature Id="ProductFeature" Title="Sentinel Agent" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentGroupRef Id="ShortcutComponents" />
      <ComponentGroupRef Id="ConfigComponents" />
      <ComponentRef Id="SentinelDataDirComponent" />
    </Feature>

    <!-- Ensure all required directories exist -->
    <ComponentGroup Id="ConfigComponents">
      <Component Id="ConfigFileComponent" Guid="C3D4E5F6-A7B8-9012-CDEF-345678901234" Directory="ConfigDir">
        <File Id="DefaultConfigFile"
              Name="agent.json"
              Source="config\agent.example.json" />
      </Component>

      <Component Id="LlmConfigFileComponent" Guid="C3D4E5F6-A7B8-9012-CDEF-345678901235" Directory="ConfigDir">
        <File Id="LlmConfigFile"
              Name="llm.json"
              Source="config\llm.example.json" />
      </Component>

      <Component Id="SigningCertComponent" Guid="F7A8B9C0-D1E2-3456-7890-ABCDEF123457" Directory="ConfigDir">
        <File Id="SigningCertFile"
              Name="sentinel-selfsigned.cer"
              Source="sentinel-selfsigned.cer"
              KeyPath="yes" />
      </Component>

      <Component Id="DocsComponent" Guid="D4E5F6A7-B8C9-0123-DEF0-456789012346" Directory="DocsDir">
        <File Id="UserGuide"
              Name="User-Guide.md"
              Source="docs\USER_GUIDE.md" />
      </Component>

      <Component Id="SentinelDataDirComponent" Guid="A2B3C4D5-E6F7-8901-ABCD-EF1234567891" Directory="SentinelDataDir">
        <CreateFolder />
      </Component>

      <Component Id="DataDirComponent" Guid="D4E5F6A7-B8C9-0123-DEF0-456789012345" Directory="DataDir">
        <CreateFolder />
      </Component>

      <Component Id="ModelsDirComponent" Guid="D4E5F6A7-B8C9-0123-DEF0-456789012347" Directory="ModelsDir">
        <CreateFolder />
      </Component>

      <Component Id="CacheLlmDirComponent" Guid="D4E5F6A7-B8C9-0123-DEF0-456789012348" Directory="CacheLlmDir">
        <CreateFolder />
      </Component>

      <Component Id="LogDirComponent" Guid="E5F6A7B8-C9D0-1234-EF01-567890123456" Directory="LogDir">
        <CreateFolder />
      </Component>
    </ComponentGroup>

    <!-- Custom Actions -->
    <CustomAction Id="InstallCertificate"
                  Directory="ConfigDir"
                  ExeCommand="powershell.exe -NoProfile -NonInteractive -WindowStyle Hidden -ExecutionPolicy RemoteSigned -Command &quot;try { $cert = '[ConfigDir]sentinel-selfsigned.cer'; certutil -addstore 'TrustedPublisher' $cert; certutil -addstore 'Root' $cert } catch { Write-EventLog -LogName Application -Source 'SentinelGRCAgent' -EventId 1003 -EntryType Error -Message ('Certificate installation failed: ' + $_) }&quot;"
                  Return="ignore" />

    <CustomAction Id="AddDefenderExclusion"
                  Directory="BinDir"
                  ExeCommand="powershell.exe -NoProfile -NonInteractive -WindowStyle Hidden -ExecutionPolicy RemoteSigned -Command &quot;try { Add-MpPreference -ExclusionPath '[INSTALLDIR]' -ExclusionProcess '[BinDir]sentinel-agent.exe' -ErrorAction SilentlyContinue } catch { Write-EventLog -LogName Application -Source 'SentinelGRCAgent' -EventId 1001 -EntryType Error -Message ('Failed to add Defender exclusion: ' + $_) }&quot;"
                  Return="ignore" />

    <CustomAction Id="CreateConfigFile"
                  Directory="SentinelDataDir"
                  ExeCommand="powershell.exe -NoProfile -NonInteractive -WindowStyle Hidden -ExecutionPolicy RemoteSigned -Command &quot;New-Item -ItemType Directory -Path '[SentinelDataDir]' -Force | Out-Null; '{&quot;&quot;server_url&quot;&quot;:&quot;&quot;[SERVERURL]&quot;&quot;,&quot;&quot;enrollment_token&quot;&quot;:&quot;&quot;[ENROLLMENTTOKEN]&quot;&quot;,&quot;&quot;check_interval_secs&quot;&quot;:3600,&quot;&quot;heartbeat_interval_secs&quot;&quot;:60,&quot;&quot;log_level&quot;&quot;:&quot;&quot;info&quot;&quot;,&quot;&quot;tls_verify&quot;&quot;:true}' | Set-Content -Path '[SentinelDataDir]agent.json' -Encoding UTF8&quot;"
                  Return="ignore" />

    <CustomAction Id="RunEnrollment"
                  Directory="BinDir"
                  ExeCommand="&quot;[BinDir]sentinel-agent.exe&quot; enroll --token &quot;[ENROLLMENTTOKEN]&quot; --server &quot;[SERVERURL]&quot;"
                  Return="ignore" />

    <CustomAction Id="LaunchGui"
                  Directory="BinDir"
                  ExeCommand="sentinel-agent.exe"
                  Return="asyncNoWait" />

    <CustomAction Id="KillGuiProcess"
                  Directory="SystemFolder"
                  ExeCommand="powershell.exe -NoProfile -NonInteractive -WindowStyle Hidden -ExecutionPolicy RemoteSigned -Command &quot;Stop-Process -Name 'sentinel-agent' -Force -ErrorAction SilentlyContinue; Start-Sleep -Seconds 2&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <CustomAction Id="RemoveDefenderExclusion"
                  Directory="BinDir"
                  ExeCommand="powershell.exe -NoProfile -NonInteractive -WindowStyle Hidden -ExecutionPolicy RemoteSigned -Command &quot;Remove-MpPreference -ExclusionPath '[INSTALLDIR]' -ExclusionProcess '[BinDir]sentinel-agent.exe' -ErrorAction SilentlyContinue&quot;"
                  Return="ignore" />

    <CustomAction Id="CleanupDataOnUninstall"
                  Directory="CommonAppDataFolder"
                  ExeCommand="powershell.exe -NoProfile -NonInteractive -WindowStyle Hidden -ExecutionPolicy RemoteSigned -Command &quot;try { Remove-Item '%ProgramData%\Sentinel\*' -Recurse -Force -ErrorAction SilentlyContinue } catch { Write-EventLog -LogName Application -Source 'SentinelGRCAgent' -EventId 1002 -EntryType Warning -Message ('Cleanup failed: ' + $_) }&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <CustomAction Id="ForceResetPermissions"
                  Directory="SystemFolder"
                  ExeCommand="powershell.exe -NoProfile -NonInteractive -WindowStyle Hidden -ExecutionPolicy RemoteSigned -Command &quot;if (Test-Path '%ProgramData%\Sentinel') { takeown /A /F '%ProgramData%\Sentinel' /R 2&gt;$null; icacls '%ProgramData%\Sentinel' /grant '*S-1-5-32-545:(OI)(CI)(F)' /T /C /Q 2&gt;$null; icacls '%ProgramData%\Sentinel' /grant '*S-1-5-32-544:(OI)(CI)(F)' /T /C /Q 2&gt;$null; icacls '%ProgramData%\Sentinel' /grant '*S-1-5-18:(OI)(CI)(F)' /T /C /Q 2&gt;$null }&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="KillGuiProcess" After="InstallInitialize"
              Condition="REMOVE=&quot;ALL&quot;" />

      <Custom Action="CleanupDataOnUninstall" After="KillGuiProcess"
              Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE" />

      <Custom Action="ForceResetPermissions" After="CleanupDataOnUninstall"
              Condition="NOT REMOVE=&quot;ALL&quot;" />

      <Custom Action="InstallCertificate" After="InstallFinalize"
              Condition="NOT Installed" />
      <Custom Action="AddDefenderExclusion" After="InstallCertificate"
              Condition="NOT Installed" />
      <Custom Action="CreateConfigFile" After="AddDefenderExclusion"
              Condition="NOT Installed AND ENROLLMENTTOKEN" />
      <Custom Action="RunEnrollment" After="CreateConfigFile"
              Condition="NOT Installed AND ENROLLMENTTOKEN" />
      <Custom Action="LaunchGui" After="RunEnrollment"
              Condition="NOT Installed" />

      <Custom Action="RemoveDefenderExclusion" After="LaunchGui"
              Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE" />
    </InstallExecuteSequence>

  </Package>
</Wix>
