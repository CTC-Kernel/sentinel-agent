#!/bin/sh
# Sentinel GRC Agent - Script post-suppression
set -e

case "$1" in
    purge)
        echo "Purge de Sentinel GRC Agent..."

        # Remove configuration and data
        rm -rf /etc/sentinel
        rm -rf /var/lib/sentinel-grc
        rm -rf /var/log/sentinel-grc

        # Remove logrotate configuration
        rm -f /etc/logrotate.d/sentinel-agent

        # Remove AppArmor profile
        rm -f /etc/apparmor.d/opt.sentinel-grc.bin.sentinel-agent
        if command -v apparmor_parser > /dev/null 2>&1; then
            apparmor_parser -R /etc/apparmor.d/opt.sentinel-grc.bin.sentinel-agent 2>/dev/null || true
        fi

        # Remove service user and group
        if id -u sentinel-grc > /dev/null 2>&1; then
            userdel sentinel-grc 2>/dev/null || true
        fi
        if getent group sentinel-grc > /dev/null 2>&1; then
            groupdel sentinel-grc 2>/dev/null || true
        fi

        echo "Toutes les donnees ont ete supprimees."
        ;;
    remove)
        echo "Sentinel GRC Agent supprime."
        echo "Configuration preservee : /etc/sentinel/"
        echo "Donnees preservees     : /var/lib/sentinel-grc/"
        echo "Pour tout supprimer    : apt purge sentinel-agent"
        ;;
    upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        ;;
    *)
        echo "postrm: argument inconnu \`$1'" >&2
        exit 1
        ;;
esac

# Reload systemd
if [ -d /run/systemd/system ]; then
    systemctl daemon-reload || true
fi

exit 0
