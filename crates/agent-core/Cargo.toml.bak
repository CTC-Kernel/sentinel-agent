[package]
name = "agent-core"
version.workspace = true
edition.workspace = true
license.workspace = true
publish = false
description = "Sentinel GRC endpoint compliance monitoring agent"

[features]
default = ["tray"]
# Enable system tray GUI (macOS/Windows desktop mode)
tray = ["dep:tray-icon", "dep:muda", "dep:image", "dep:open", "dep:tao"]
# Enable v2 desktop GUI features (Tauri-based)
# gui = ["agent-gui", "agent-persistence"]
# fim = ["agent-fim"]
# llm_simple = ["agent-llm"]

[dependencies]
agent_scanner = { path = "../agent_scanner" }
serde_json.workspace = true
agent-common = { path = "../agent-common" }

thiserror.workspace = true
anyhow.workspace = true
tracing.workspace = true
uuid.workspace = true
chrono.workspace = true
reqwest.workspace = true
rusqlite = { version = "0.37", features = ["bundled-sqlcipher"] }
tokio-rusqlite = "0.7"

tracing-subscriber = { version = "0.3", features = ["json", "env-filter"] }
config = "0.15"
directories = "6"
url = "2"
tempfile = "3"
sha2 = "0.10"
hex = "0.4"
libc = "0.2"
clap = { version = "4", features = ["derive"] }
signal-hook = "0.3"
sysinfo = "0.35"
async-trait = "0.1"
semver = { version = "1", features = ["serde"] }
hmac = "0.12"
tray-icon = { workspace = true, optional = true }
muda = { workspace = true, optional = true }
image = { workspace = true, default-features = false, features = ["png"], optional = true }
open = { workspace = true, optional = true }
tao = { workspace = true, default-features = false, features = ["rwh_06"], optional = true }
hostname = "0.4"
rand = "0.9"
eframe = "0.31"
egui = "0.31"
egui_extras = { version = "0.31", features = ["image"] }
egui_plot = "0.31"
notify = { version = "7", features = ["macos_fsevent"] }
rayon = "1.10"
battery = "0.7"
usb_enumeration = "0.2"
walkdir = "2"
blake3 = "1"
memmap2 = "0.9"
regex = "1"

windows = { workspace = true }

[target.'cfg(unix)'.dependencies]
libc = { workspace = true }

[profile.release]
lto = "thin"
codegen-units = 1
strip = true
panic = "abort"
overflow-checks = true
opt-level = 3
debug = true

[profile.dev]
debug = true
strip = false
opt-level = 0
overflow-checks = false
