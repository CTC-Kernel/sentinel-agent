<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow network connections (client and server) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- Allow reading/writing user-selected files -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Allow access to downloads folder -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>

    <!-- Hardened runtime exceptions needed for the agent -->
    <!-- Allow unsigned executable memory (for JIT if needed) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <false/>

    <!-- Allow DYLD environment variables (for debugging) -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <false/>

    <!-- Disable library validation (if loading external libs) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <false/>
</dict>
</plist>
